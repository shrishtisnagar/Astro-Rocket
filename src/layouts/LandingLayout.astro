---
/**
 * LandingLayout
 * Layout wrapper for landing-style pages (marketing, demo, showcase)
 * Uses Header + Footer with landing-specific configuration
 *
 * This layout is part of the "demo" layer - it can be optionally installed
 * via CLI for users who want the full landing page experience.
 */
import BaseLayout from './BaseLayout.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import { url } from '@/lib/url';

interface Props {
  title?: string;
  /** When set, used verbatim as the <title> — skips the automatic "title — Site Name" template. */
  titleFull?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
  includePersonSchema?: boolean;
  includeProfessionalServiceSchema?: boolean;
  showContactFooter?: boolean;
}

const {
  title,
  titleFull,
  description,
  image,
  imageAlt,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
  includePersonSchema = false,
  includeProfessionalServiceSchema = false,
  showContactFooter = false,
} = Astro.props;
---

<BaseLayout
  title={title}
  titleFull={titleFull}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  includeOrgSchema={includeOrgSchema}
  includePersonSchema={includePersonSchema}
  includeProfessionalServiceSchema={includeProfessionalServiceSchema}
>
  <slot />

  <Footer slot="footer" layout="simple" background="secondary" copyright="© {year} The S Curve | Shrishti S Nagar — Serving Global Clients From India" videoBg={url("/videos/hero-bg.mp4")} videoSpeed={0.825}>
    {showContactFooter && <ContactFooterSection slot="top" />}
  </Footer>
</BaseLayout>
