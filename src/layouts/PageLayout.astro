---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import { url } from '@/lib/url';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  eagerReveal?: boolean;
  showContactFooter?: boolean;
}

const { title, description, image, imageAlt, noindex, nofollow, eagerReveal = false, showContactFooter = true } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
>
  <main class="min-h-screen">
    <slot />
  </main>

  <Footer slot="footer" layout="simple" videoBg={url("/videos/hero-bg.mp4")} videoSpeed={0.825}>
    {showContactFooter && <ContactFooterSection slot="top" />}
  </Footer>
</BaseLayout>
