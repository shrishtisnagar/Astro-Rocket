---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
  eagerReveal?: boolean;
  showContactFooter?: boolean;
}

const { title, description, image, imageAlt, noindex, nofollow, showScrollProgress = false, eagerReveal = false, showContactFooter = true } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showActiveState
    showCta={false}
    showThemeToggle={false}
    showScrollProgress={showScrollProgress}
  />

  <main class="min-h-screen pt-16">
    <slot />
    {showContactFooter && <ContactFooterSection />}
  </main>

  <Footer slot="footer" layout="simple" videoBg="/videos/hero-bg.mp4" videoSpeed={0.825} />
</BaseLayout>
