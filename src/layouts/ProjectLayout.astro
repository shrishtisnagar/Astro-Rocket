---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { url as assetUrl } from '@/lib/url';

interface Props {
  title: string;
  description: string;
  year?: number;
  client?: string;
  role?: string;
  services?: string[];
  url?: string;
  repo?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageUrl?: string;
  imageAlt?: string;
  related?: CollectionEntry<'projects'>[];
}

const {
  title,
  description,
  year,
  client,
  role,
  services: _services = [],
  url,
  repo,
  tags = [],
  image,
  imageUrl,
  imageAlt,
  related = [],
} = Astro.props;

const ogImage = image?.src || siteConfig.ogImage;

// Resolve hero image source
const heroImageSrc = image
  ? image.src
  : imageUrl
    ? (imageUrl.startsWith('http') ? imageUrl : assetUrl(imageUrl.startsWith('/') ? imageUrl : `/${imageUrl}`))
    : null;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
>
  <!-- Header: no scroll-progress bar (panel scroll, not window) -->
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showCta={false}
    showScrollProgress={false}
  />

  <!-- ╔════════════════════════════════════════════╗
       ║  TWO-PANE CASE STUDY SHELL                ║
       ║  Left: fixed identity + TOC               ║
       ║  Right: scrollable cinematic content      ║
       ╚════════════════════════════════════════════╝ -->
  <div class="cs-shell" id="cs-shell">

    <!-- ══════════ LEFT SIDEBAR ══════════ -->
    <aside class="cs-sidebar" id="cs-sidebar" aria-label="Case study navigation">
      <div class="cs-sidebar-inner">

        <!-- Back navigation -->
        <a href={assetUrl('/projects')} class="cs-back">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          All projects
        </a>

        <!-- Project identity -->
        <div class="cs-identity">
          {tags.length > 0 && (
            <div class="cs-id-tags">
              {tags.map((tag) => (
                <span class="cs-id-tag">{tag}</span>
              ))}
            </div>
          )}
          <h2 class="cs-id-title">{title}</h2>
          {description && (
            <p class="cs-id-desc">{description}</p>
          )}
        </div>

        <!-- Meta grid -->
        {(year || client || role) && (
          <dl class="cs-meta">
            {year && (
              <>
                <dt class="cs-meta-label">Year</dt>
                <dd class="cs-meta-value">{year}</dd>
              </>
            )}
            {client && (
              <>
                <dt class="cs-meta-label">Client</dt>
                <dd class="cs-meta-value">{client}</dd>
              </>
            )}
            {role && (
              <>
                <dt class="cs-meta-label">Role</dt>
                <dd class="cs-meta-value">{role}</dd>
              </>
            )}
          </dl>
        )}

        <!-- External CTA -->
        {url && (
          <a href={url} target="_blank" rel="noopener noreferrer" class="cs-id-cta">
            View case study
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer" class="cs-id-cta cs-id-cta--secondary">
            View source
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}

        <!-- Project image fills the remaining sidebar space -->
        {heroImageSrc && (
          <div class="cs-sidebar-image">
            <img
              src={heroImageSrc}
              alt={imageAlt || title}
              class="cs-sidebar-img"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

      </div>
    </aside>

    <!-- ══════════ RIGHT PANEL (scrolls) ══════════ -->
    <div class="cs-panel" id="cs-panel">

      <!-- ─── Cinematic hero: full panel height ─── -->
      <div class="cs-hero" id="cs-hero">
        {heroImageSrc
          ? (
            <div class="cs-hero-image-wrap" aria-hidden="true">
              <img
                src={heroImageSrc}
                alt=""
                class="cs-hero-img"
                loading="eager"
                decoding="async"
              />
            </div>
          )
          : (
            <div class="cs-hero-fallback" aria-hidden="true"></div>
          )
        }
        <div class="cs-hero-gradient" aria-hidden="true"></div>

        <div class="cs-hero-content">
          {tags.length > 0 && (
            <div class="cs-hero-tags">
              {tags.map((tag) => (
                <span class="cs-hero-tag">{tag}</span>
              ))}
            </div>
          )}
          <h1 class="cs-hero-title">{title}</h1>
          <p class="cs-hero-desc">{description}</p>

          <!-- Animated scroll hint -->
          <div class="cs-scroll-hint" aria-hidden="true">
            <span class="cs-scroll-hint-label">Scroll to read</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              class="cs-scroll-hint-icon" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>
      </div>

      <!-- ─── Article prose ─── -->
      <article class="cs-article" id="cs-article">
        <div class="prose prose-lg dark:prose-invert">
          <slot />
        </div>

        <div class="cs-article-footer" data-reveal>
          <a href={assetUrl('/projects')} class="cs-back-inline">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Projects
          </a>
        </div>
      </article>

    </div><!-- /cs-panel -->
  </div><!-- /cs-shell -->

  <!-- ══ Normal document flow: scrolled to after the shell ══ -->
  {related.length > 0 && (
    <section class="cs-related" data-reveal>
      <div class="cs-related-inner">
        <h2 class="cs-related-title">More projects</h2>
        <div class="cs-related-grid">
          {related.map((project) => {
            const slug = project.id.replace(/\.mdx?$/, '');
            const hasBody = project.body && project.body.trim().length > 0;
            return (
              <a
                href={hasBody ? assetUrl(`/projects/${slug}`) : project.data.url}
                target={hasBody ? undefined : '_blank'}
                rel={hasBody ? undefined : 'noopener noreferrer'}
                class="rp-card group block"
              >
                <div class="rp-card-inner">
                  <div class="rp-img">
                    {project.data.imageUrl && (
                      <img
                        src={project.data.imageUrl.startsWith('/') ? assetUrl(project.data.imageUrl) : project.data.imageUrl}
                        alt={project.data.imageAlt || project.data.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    )}
                  </div>
                  <div class="rp-overlay">
                    <div class="rp-title-row">
                      <h3 class="rp-title">{project.data.title}</h3>
                      <Icon name="arrow-up-right" size="sm" class="rp-arrow" />
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <ContactFooterSection
    videoBg={assetUrl("/videos/hero-bg.mp4")}
    videoSpeed={0.825}
  />
</BaseLayout>

<!-- ════════════════════════════════════════════════════════
     STYLES
     ════════════════════════════════════════════════════════ -->
<style>
  /* ── CSS variables ── */
  :root {
    --cs-header-h: 4rem;    /* must match Header size="lg" (h-16) */
    --cs-sidebar-w: 300px;
  }

  /* Hide default back-to-top on case study pages */
  :global(#back-to-top) {
    display: none !important;
  }

  /* ════════════════════════
     TWO-PANE SHELL
     ════════════════════════ */
  .cs-shell {
    display: flex;
    height: calc(100dvh - var(--cs-header-h));
    margin-top: var(--cs-header-h);
    overflow: hidden;
    position: relative;
  }

  /* ════════════════════════
     LEFT SIDEBAR
     ════════════════════════ */
  .cs-sidebar {
    width: var(--cs-sidebar-w);
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    border-right: 1px solid var(--color-border);
    background: var(--color-background);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .cs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem 1.375rem 3rem;
    min-height: 100%;
  }

  /* Back link */
  .cs-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back:hover {
    color: var(--color-foreground-muted);
  }

  /* Identity block */
  .cs-identity {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cs-id-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .cs-id-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-brand-700);
  }
  :global(.dark) .cs-id-tag {
    background: color-mix(in oklch, var(--color-brand-900) 45%, transparent);
    color: var(--color-brand-300);
  }

  .cs-id-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground);
    margin: 0;
  }

  .cs-id-desc {
    font-size: 0.7875rem;
    line-height: 1.65;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* Meta key-value grid */
  .cs-meta {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.75rem;
    row-gap: 0.325rem;
    align-items: baseline;
    margin: 0;
  }
  .cs-meta-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
  }
  .cs-meta-value {
    font-size: 0.8rem;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* CTA buttons */
  .cs-id-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .cs-id-cta:hover {
    color: var(--color-brand-500);
    gap: 0.55rem;
  }
  .cs-id-cta--secondary {
    color: var(--color-foreground-muted);
  }
  .cs-id-cta--secondary:hover {
    color: var(--color-foreground);
  }
  :global(.dark) .cs-id-cta {
    color: var(--color-brand-400);
  }
  :global(.dark) .cs-id-cta:hover {
    color: var(--color-brand-300);
  }

  /* ── Sidebar image ── */
  .cs-sidebar-image {
    flex: 1;
    min-height: 240px;
    overflow: hidden;
    border-radius: 0.75rem;
    margin-top: auto;
  }

  .cs-sidebar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .cs-sidebar:hover .cs-sidebar-img {
    transform: scale(1.03);
  }

  /* ════════════════════════
     RIGHT PANEL
     ════════════════════════ */
  .cs-panel {
    flex: 1;
    min-width: 0;
    height: 100%;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  /* ════════════════════════
     CINEMATIC HERO
     ════════════════════════ */
  .cs-hero {
    position: relative;
    height: calc(100dvh - var(--cs-header-h));
    overflow: hidden;
    background: oklch(8% 0.015 250); /* deep dark fallback */
  }

  .cs-hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .cs-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Heavy blur turns any image into an atmospheric backdrop —
       scale up prevents visible blur edges */
    filter: blur(18px) brightness(0.28) saturate(1.6);
    transform: scale(1.12);
    will-change: filter;
  }

  .cs-hero-fallback {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 70% at 60% 40%, oklch(20% 0.06 280), oklch(6% 0.02 250) 70%);
  }

  .cs-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(0, 0, 0, 0.94) 0%,
        rgba(0, 0, 0, 0.60) 30%,
        rgba(0, 0, 0, 0.18) 60%,
        transparent 100%
      );
    pointer-events: none;
  }

  .cs-hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 5vw, 3.5rem);
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  .cs-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.125rem;
  }

  .cs-hero-tag {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.10);
    color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cs-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0 0 0.875rem;
    max-width: 18ch;
  }

  .cs-hero-desc {
    font-size: clamp(0.875rem, 1.5vw, 1.0625rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 2.25rem;
    max-width: 52ch;
  }

  /* Scroll hint */
  .cs-scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.55;
  }
  .cs-scroll-hint-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }
  .cs-scroll-hint-icon {
    color: rgba(255, 255, 255, 0.8);
    animation: cs-bounce 1.8s ease-in-out infinite;
  }

  @keyframes cs-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* ════════════════════════
     ARTICLE
     ════════════════════════ */
  .cs-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
  }

  /* ── Prose content overrides ── */

  /* Fix 1: width — prose defaults to ~65ch; .cs-article centres it */

  /* Fix 2: h2 section headings → calm editorial chapter markers */
  .cs-article :global(.prose h2) {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    border-left: 3px solid var(--color-brand-500);
    padding-left: 0.875rem;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }
  :global(.dark) .cs-article :global(.prose h2) {
    color: var(--color-brand-400);
    border-left-color: var(--color-brand-400);
  }

  /* h3 gets a quieter version */
  .cs-article :global(.prose h3) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  /* Fix 3: images — rounded corners, visible ring + shadow on dark bg */
  .cs-article :global(.prose img) {
    border-radius: 0.75rem;
    /* Bright ring makes screenshots visible against dark backgrounds;
       drop shadow adds depth without blending into the dark panel */
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.10),
      0 4px 6px -2px rgba(0, 0, 0, 0.5),
      0 12px 40px -4px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.09);
    display: block;
    margin-left: auto;
    margin-right: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Fix 4 (reading strain): slightly off-white body text + more air */
  .cs-article :global(.prose p),
  .cs-article :global(.prose li) {
    color: rgba(255, 255, 255, 0.80);
    line-height: 1.9;
  }

  .cs-article :global(.prose strong) {
    color: rgba(255, 255, 255, 0.95);
  }

  /* Fix 4: stat tables — distinct background, bold header row */
  .cs-article :global(.prose table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 0.625rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin-top: 1.75rem;
    margin-bottom: 1.75rem;
    font-size: 0.875rem;
  }

  .cs-article :global(.prose thead) {
    background: oklch(22% 0.04 280);
  }

  .cs-article :global(.prose thead th) {
    padding: 0.75rem 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: left;
  }

  .cs-article :global(.prose tbody tr) {
    background: oklch(14% 0.01 270);
    transition: background 0.15s ease;
  }

  .cs-article :global(.prose tbody tr:hover) {
    background: oklch(18% 0.03 280);
  }

  .cs-article :global(.prose tbody tr:nth-child(even)) {
    background: oklch(16% 0.015 270);
  }

  .cs-article :global(.prose tbody td) {
    padding: 0.625rem 1rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-foreground-muted);
    vertical-align: middle;
  }

  .cs-article :global(.prose tbody td:first-child) {
    font-weight: 500;
    color: var(--color-foreground);
  }

  .cs-article-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding-top: 2rem;
  }

  .cs-back-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back-inline:hover { color: var(--color-brand-500); }
  :global(.dark) .cs-back-inline { color: var(--color-brand-400); }
  :global(.dark) .cs-back-inline:hover { color: var(--color-brand-300); }

  /* ════════════════════════
     RELATED PROJECTS
     ════════════════════════ */
  .cs-related {
    border-top: 1px solid var(--color-border);
    background: var(--color-background-secondary);
    padding: 3rem 2rem;
  }

  .cs-related-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .cs-related-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 1.375rem;
  }

  .cs-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  /* ── Related card styles (same design as projects page) ── */
  .rp-card-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 1 / 1;
    box-shadow: 0 4px 24px -4px rgba(0, 0, 0, 0.18);
  }

  .rp-img {
    position: absolute;
    inset: 0;
    background: oklch(18% 0.02 344);
  }

  .rp-img img {
    filter: grayscale(100%);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .rp-card:hover .rp-img img {
    filter: grayscale(0%);
  }

  .rp-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.125rem;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 40%, transparent 75%);
    transition: background 0.4s ease;
  }

  .rp-card:hover .rp-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.60) 50%, rgba(0,0,0,0.10) 100%);
  }

  .rp-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .rp-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .rp-arrow {
    color: rgba(255, 255, 255, 0.65);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .rp-card:hover .rp-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  /* ════════════════════════
     RESPONSIVE
     ════════════════════════ */

  /* Tablet: narrower sidebar */
  @media (min-width: 768px) and (max-width: 1100px) {
    :root { --cs-sidebar-w: 240px; }
    .cs-id-desc { display: none; } /* reclaim space on tight tablets */
    .cs-related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile: stack vertically, sidebar above content */
  @media (max-width: 767px) {
    .cs-shell {
      flex-direction: column;
      height: auto;
      overflow: visible;
      margin-top: var(--cs-header-h);
    }

    .cs-sidebar {
      width: 100%;
      height: auto;
      overflow: visible;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .cs-sidebar-inner {
      padding: 1.25rem 1.25rem 1.5rem;
    }

    .cs-panel {
      height: auto;
      overflow: visible;
    }

    .cs-hero {
      height: calc(100dvh - var(--cs-header-h));
    }

    .cs-article {
      padding: 2.5rem 1.25rem 2rem;
    }

    .cs-related {
      padding: 2rem 1.25rem;
    }

    .cs-related-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── PROBLEM / OBJECTIVE callout boxes (injected by JS) ── */
  :global(.cs-callout) {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-brand-500);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 1.375rem 1.5rem 1.375rem 1.25rem;
    background: color-mix(in oklch, var(--color-background-secondary) 65%, transparent);
    margin: 2rem 0;
  }
  /* The h2 inside the box already has a left border from the section style —
     remove it since the box provides the visual anchor */
  :global(.cs-callout) :global(h2) {
    border-left: none !important;
    padding-left: 0 !important;
    margin-top: 0 !important;
  }
  :global(.cs-callout) :global(p),
  :global(.cs-callout) :global(li) {
    margin-bottom: 0;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cs-hero-img {
      transform: scale(1.12); /* keep the scale, skip transition */
    }
    .cs-scroll-hint-icon {
      animation: none;
    }
    .rp-img img {
      transition: none;
    }
  }
</style>

<script is:inline>
(function () {
  'use strict';

  function initCallouts() {
    const article = document.getElementById('cs-article');
    if (!article) return;

    const prose = article.querySelector('.prose');
    if (!prose) return;

    // Keywords that warrant a callout box
    const KEYWORDS = ['PROBLEM', 'OBJECTIVE', 'CHALLENGE', 'GOAL', 'GOALS'];

    const h2s = Array.prototype.slice.call(prose.querySelectorAll('h2'));

    h2s.forEach(function (h2) {
      // Skip if already wrapped
      if (h2.closest('.cs-callout')) return;

      const text = h2.textContent.replace(/[*_#:`]/g, '').trim().toUpperCase();
      const isCallout = KEYWORDS.some(function (kw) { return text.includes(kw); });
      if (!isCallout) return;

      // Gather this h2 + all following siblings until the next h2
      const members = [h2];
      let cursor = h2.nextElementSibling;
      while (cursor && cursor.tagName !== 'H2') {
        members.push(cursor);
        cursor = cursor.nextElementSibling;
      }

      // Wrap in callout box
      const box = document.createElement('div');
      box.className = 'cs-callout';
      prose.insertBefore(box, h2);
      members.forEach(function (el) { box.appendChild(el); });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCallouts);
  } else {
    initCallouts();
  }
  document.addEventListener('astro:page-load', initCallouts);
})();
</script>

