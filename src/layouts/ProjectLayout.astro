---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { url as assetUrl } from '@/lib/url';

interface Props {
  title: string;
  description: string;
  year?: number;
  client?: string;
  role?: string;
  services?: string[];
  url?: string;
  repo?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageUrl?: string;
  imageAlt?: string;
  related?: CollectionEntry<'projects'>[];
}

const {
  title,
  description,
  year,
  client,
  role,
  services: _services = [],
  url,
  repo,
  tags = [],
  image,
  imageUrl,
  imageAlt,
  related = [],
} = Astro.props;

const ogImage = image?.src || siteConfig.ogImage;

// Resolve hero image source
const heroImageSrc = image
  ? image.src
  : imageUrl
    ? (imageUrl.startsWith('http') ? imageUrl : assetUrl(imageUrl.startsWith('/') ? imageUrl : `/${imageUrl}`))
    : null;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
>
  <!-- Header: no scroll-progress bar (panel scroll, not window) -->
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showCta={false}
    showScrollProgress={false}
  />

  <!-- ╔════════════════════════════════════════════╗
       ║  TWO-PANE CASE STUDY SHELL                ║
       ║  Left: fixed identity + TOC               ║
       ║  Right: scrollable cinematic content      ║
       ╚════════════════════════════════════════════╝ -->
  <div class="cs-shell" id="cs-shell">

    <!-- ══════════ LEFT SIDEBAR ══════════ -->
    <aside class="cs-sidebar" id="cs-sidebar" aria-label="Case study navigation">
      <div class="cs-sidebar-inner">

        <!-- Back navigation -->
        <a href={assetUrl('/projects')} class="cs-back">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          All projects
        </a>

        <!-- Project identity -->
        <div class="cs-identity">
          {tags.length > 0 && (
            <div class="cs-id-tags">
              {tags.map((tag) => (
                <span class="cs-id-tag">{tag}</span>
              ))}
            </div>
          )}
          <h2 class="cs-id-title">{title}</h2>
          {description && (
            <p class="cs-id-desc">{description}</p>
          )}
        </div>

        <!-- Meta grid -->
        {(year || client || role) && (
          <dl class="cs-meta">
            {year && (
              <>
                <dt class="cs-meta-label">Year</dt>
                <dd class="cs-meta-value">{year}</dd>
              </>
            )}
            {client && (
              <>
                <dt class="cs-meta-label">Client</dt>
                <dd class="cs-meta-value">{client}</dd>
              </>
            )}
            {role && (
              <>
                <dt class="cs-meta-label">Role</dt>
                <dd class="cs-meta-value">{role}</dd>
              </>
            )}
          </dl>
        )}

        <!-- External CTA -->
        {url && (
          <a href={url} target="_blank" rel="noopener noreferrer" class="cs-id-cta">
            View case study
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer" class="cs-id-cta cs-id-cta--secondary">
            View source
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}

        <!-- Divider -->
        <div class="cs-sidebar-divider" aria-hidden="true"></div>

        <!-- Table of contents (populated by JS from article headings) -->
        <nav class="cs-toc" id="cs-toc" aria-label="Table of contents">
          <p class="cs-toc-heading">On this page</p>
          <ul class="cs-toc-list" id="cs-toc-list" role="list">
            <!-- filled by initCaseTOC() -->
          </ul>
        </nav>

      </div>
    </aside>

    <!-- ══════════ RIGHT PANEL (scrolls) ══════════ -->
    <div class="cs-panel" id="cs-panel">

      <!-- ─── Cinematic hero: full panel height ─── -->
      <div class="cs-hero" id="cs-hero">
        {heroImageSrc
          ? (
            <div class="cs-hero-image-wrap" aria-hidden="true">
              <img
                src={heroImageSrc}
                alt=""
                class="cs-hero-img"
                loading="eager"
                decoding="async"
              />
            </div>
          )
          : (
            <div class="cs-hero-fallback" aria-hidden="true"></div>
          )
        }
        <div class="cs-hero-gradient" aria-hidden="true"></div>

        <div class="cs-hero-content">
          {tags.length > 0 && (
            <div class="cs-hero-tags">
              {tags.map((tag) => (
                <span class="cs-hero-tag">{tag}</span>
              ))}
            </div>
          )}
          <h1 class="cs-hero-title">{title}</h1>
          <p class="cs-hero-desc">{description}</p>

          <!-- Animated scroll hint -->
          <div class="cs-scroll-hint" aria-hidden="true">
            <span class="cs-scroll-hint-label">Scroll to read</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
              class="cs-scroll-hint-icon" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </div>
        </div>
      </div>

      <!-- ─── Article prose ─── -->
      <article class="cs-article" id="cs-article">
        <div class="prose prose-lg max-w-none dark:prose-invert" data-reveal-content>
          <slot />
        </div>

        <div class="cs-article-footer" data-reveal>
          <a href={assetUrl('/projects')} class="cs-back-inline">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Projects
          </a>
        </div>
      </article>

      <!-- ─── Related projects ─── -->
      {related.length > 0 && (
        <section class="cs-related" data-reveal>
          <div class="cs-related-inner">
            <h2 class="cs-related-title">More projects</h2>
            <div class="cs-related-grid">
              {related.map((project) => {
                const slug = project.id.replace(/\.mdx?$/, '');
                const hasBody = project.body && project.body.trim().length > 0;
                return (
                  <a
                    href={hasBody ? assetUrl(`/projects/${slug}`) : project.data.url}
                    target={hasBody ? undefined : '_blank'}
                    rel={hasBody ? undefined : 'noopener noreferrer'}
                    class="rp-card group block"
                  >
                    <div class="rp-card-inner">
                      <div class="rp-img">
                        {project.data.imageUrl && (
                          <img
                            src={project.data.imageUrl.startsWith('/') ? assetUrl(project.data.imageUrl) : project.data.imageUrl}
                            alt={project.data.imageAlt || project.data.title}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                          />
                        )}
                      </div>
                      <div class="rp-overlay">
                        <div class="rp-title-row">
                          <h3 class="rp-title">{project.data.title}</h3>
                          <Icon name="arrow-up-right" size="sm" class="rp-arrow" />
                        </div>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      )}

      <ContactFooterSection
        videoBg={assetUrl("/videos/hero-bg.mp4")}
        videoSpeed={0.825}
      />

    </div><!-- /cs-panel -->
  </div><!-- /cs-shell -->

  <!-- No footer slot: case study shell is self-contained.
       The empty slot means footer-reveal-wrap has 0 height,
       so no margin-bottom is added to page-content-wrap. -->
</BaseLayout>

<!-- ════════════════════════════════════════════════════════
     STYLES
     ════════════════════════════════════════════════════════ -->
<style>
  /* ── CSS variables ── */
  :root {
    --cs-header-h: 4rem;    /* must match Header size="lg" (h-16) */
    --cs-sidebar-w: 300px;
  }

  /* Hide default back-to-top on case study pages
     (window doesn't scroll — panel does) */
  :global(#back-to-top) {
    display: none !important;
  }

  /* Disable the footer-reveal margin added by BaseLayout JS */
  :global(.page-content-wrap) {
    margin-bottom: 0 !important;
  }

  /* ════════════════════════
     TWO-PANE SHELL
     ════════════════════════ */
  .cs-shell {
    display: flex;
    height: calc(100dvh - var(--cs-header-h));
    margin-top: var(--cs-header-h);
    overflow: hidden;
    position: relative;
  }

  /* ════════════════════════
     LEFT SIDEBAR
     ════════════════════════ */
  .cs-sidebar {
    width: var(--cs-sidebar-w);
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    border-right: 1px solid var(--color-border);
    background: var(--color-background);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .cs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem 1.375rem 3rem;
    min-height: 100%;
  }

  /* Back link */
  .cs-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back:hover {
    color: var(--color-foreground-muted);
  }

  /* Identity block */
  .cs-identity {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cs-id-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .cs-id-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-brand-700);
  }
  :global(.dark) .cs-id-tag {
    background: color-mix(in oklch, var(--color-brand-900) 45%, transparent);
    color: var(--color-brand-300);
  }

  .cs-id-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground);
    margin: 0;
  }

  .cs-id-desc {
    font-size: 0.7875rem;
    line-height: 1.65;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* Meta key-value grid */
  .cs-meta {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.75rem;
    row-gap: 0.325rem;
    align-items: baseline;
    margin: 0;
  }
  .cs-meta-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
  }
  .cs-meta-value {
    font-size: 0.8rem;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* CTA buttons */
  .cs-id-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .cs-id-cta:hover {
    color: var(--color-brand-500);
    gap: 0.55rem;
  }
  .cs-id-cta--secondary {
    color: var(--color-foreground-muted);
  }
  .cs-id-cta--secondary:hover {
    color: var(--color-foreground);
  }
  :global(.dark) .cs-id-cta {
    color: var(--color-brand-400);
  }
  :global(.dark) .cs-id-cta:hover {
    color: var(--color-brand-300);
  }

  /* Divider */
  .cs-sidebar-divider {
    height: 1px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* ── Table of Contents ── */
  .cs-toc {
    flex: 1;
    min-height: 0;
  }

  .cs-toc-heading {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
    margin: 0 0 0.625rem;
  }

  .cs-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.0625rem;
  }

  /* TOC items are injected by JS — use :global() */
  :global(.cs-toc-item) > a {
    display: block;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-foreground-muted);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border-left: 2px solid transparent;
    border-radius: 0 0.25rem 0.25rem 0;
    transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }
  :global(.cs-toc-item) > a:hover {
    color: var(--color-foreground);
    background: var(--color-background-secondary);
  }
  :global(.cs-toc-item.is-active) > a {
    color: var(--color-brand-600);
    border-left-color: var(--color-brand-500);
    background: color-mix(in oklch, var(--color-brand-500) 8%, transparent);
  }
  :global(.dark .cs-toc-item.is-active) > a {
    color: var(--color-brand-400);
  }
  /* h3 items indented */
  :global(.cs-toc-item.cs-h3) > a {
    padding-left: 1.375rem;
    font-size: 0.75rem;
  }

  /* ════════════════════════
     RIGHT PANEL
     ════════════════════════ */
  .cs-panel {
    flex: 1;
    min-width: 0;
    height: 100%;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  /* ════════════════════════
     CINEMATIC HERO
     ════════════════════════ */
  .cs-hero {
    position: relative;
    height: calc(100dvh - var(--cs-header-h));
    overflow: hidden;
    background: oklch(8% 0.015 250); /* deep dark fallback */
  }

  .cs-hero-image-wrap {
    position: absolute;
    inset: 0;
  }

  .cs-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(45%) brightness(0.55);
    transform: scale(1.04);
    transition:
      filter 1.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 14s ease;
    will-change: filter, transform;
  }

  .cs-hero:hover .cs-hero-img {
    filter: grayscale(0%) brightness(0.72);
    transform: scale(1.0);
  }

  .cs-hero-fallback {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 70% at 60% 40%, oklch(20% 0.06 280), oklch(6% 0.02 250) 70%);
  }

  .cs-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(0, 0, 0, 0.94) 0%,
        rgba(0, 0, 0, 0.60) 30%,
        rgba(0, 0, 0, 0.18) 60%,
        transparent 100%
      );
    pointer-events: none;
  }

  .cs-hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 5vw, 3.5rem);
    padding-bottom: clamp(2.5rem, 6vw, 5rem);
  }

  .cs-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.125rem;
  }

  .cs-hero-tag {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.10);
    color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cs-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: #fff;
    margin: 0 0 0.875rem;
    max-width: 18ch;
  }

  .cs-hero-desc {
    font-size: clamp(0.875rem, 1.5vw, 1.0625rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 2.25rem;
    max-width: 52ch;
  }

  /* Scroll hint */
  .cs-scroll-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.55;
  }
  .cs-scroll-hint-label {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8);
  }
  .cs-scroll-hint-icon {
    color: rgba(255, 255, 255, 0.8);
    animation: cs-bounce 1.8s ease-in-out infinite;
  }

  @keyframes cs-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* ════════════════════════
     ARTICLE
     ════════════════════════ */
  .cs-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
  }

  .cs-article-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding-top: 2rem;
  }

  .cs-back-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back-inline:hover { color: var(--color-brand-500); }
  :global(.dark) .cs-back-inline { color: var(--color-brand-400); }
  :global(.dark) .cs-back-inline:hover { color: var(--color-brand-300); }

  /* ════════════════════════
     RELATED PROJECTS
     ════════════════════════ */
  .cs-related {
    border-top: 1px solid var(--color-border);
    background: var(--color-background-secondary);
    padding: 3rem 2rem;
  }

  .cs-related-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .cs-related-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 1.375rem;
  }

  .cs-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  /* ── Related card styles (same design as projects page) ── */
  .rp-card-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 1 / 1;
    box-shadow: 0 4px 24px -4px rgba(0, 0, 0, 0.18);
  }

  .rp-img {
    position: absolute;
    inset: 0;
    background: oklch(18% 0.02 344);
  }

  .rp-img img {
    filter: grayscale(100%);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .rp-card:hover .rp-img img {
    filter: grayscale(0%);
  }

  .rp-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.125rem;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 40%, transparent 75%);
    transition: background 0.4s ease;
  }

  .rp-card:hover .rp-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.60) 50%, rgba(0,0,0,0.10) 100%);
  }

  .rp-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .rp-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .rp-arrow {
    color: rgba(255, 255, 255, 0.65);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .rp-card:hover .rp-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  /* ════════════════════════
     RESPONSIVE
     ════════════════════════ */

  /* Tablet: narrower sidebar */
  @media (min-width: 768px) and (max-width: 1100px) {
    :root { --cs-sidebar-w: 240px; }
    .cs-id-desc { display: none; } /* reclaim space on tight tablets */
    .cs-related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile: stack vertically, sidebar above content */
  @media (max-width: 767px) {
    .cs-shell {
      flex-direction: column;
      height: auto;
      overflow: visible;
      margin-top: var(--cs-header-h);
    }

    .cs-sidebar {
      width: 100%;
      height: auto;
      overflow: visible;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .cs-sidebar-inner {
      padding: 1.25rem 1.25rem 1.5rem;
    }

    /* On mobile, collapse TOC — too much vertical space */
    .cs-toc {
      display: none;
    }

    .cs-panel {
      height: auto;
      overflow: visible;
    }

    .cs-hero {
      height: calc(100dvh - var(--cs-header-h));
    }

    .cs-article {
      padding: 2.5rem 1.25rem 2rem;
    }

    .cs-related {
      padding: 2rem 1.25rem;
    }

    .cs-related-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cs-hero-img {
      transition: filter 0.3s ease;
      transform: none !important;
    }
    .cs-scroll-hint-icon {
      animation: none;
    }
    .rp-img img {
      transition: none;
    }
  }
</style>

<!-- ════════════════════════════════════════════════════════
     SCRIPTS: TOC builder + panel-scroll IntersectionObserver
     ════════════════════════════════════════════════════════ -->
<script is:inline>
(function () {
  'use strict';

  function initCaseTOC() {
    const panel   = document.getElementById('cs-panel');
    const tocList = document.getElementById('cs-toc-list');
    const tocNav  = document.getElementById('cs-toc');
    if (!panel || !tocList || !tocNav) return;

    // Collect headings from inside the article only
    const article = panel.querySelector('.cs-article');
    if (!article) return;

    const headings = Array.prototype.slice.call(
      article.querySelectorAll('h2, h3')
    );

    if (!headings.length) {
      tocNav.style.display = 'none';
      return;
    }

    // Ensure every heading has an id
    headings.forEach(function (h, i) {
      if (!h.id) {
        const slug = h.textContent
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .slice(0, 48);
        h.id = 'cs-h-' + i + '-' + slug;
      }
    });

    // Build TOC list items
    tocList.innerHTML = '';
    const items = [];
    headings.forEach(function (h) {
      const li = document.createElement('li');
      li.className = 'cs-toc-item ' + (h.tagName === 'H3' ? 'cs-h3' : 'cs-h2');

      const a = document.createElement('a');
      a.href = '#' + h.id;
      // Strip markdown bold/italic markers that end up in text
      a.textContent = h.textContent.replace(/[*_#`]/g, '').trim();

      // Smooth-scroll inside the panel on click
      a.addEventListener('click', function (e) {
        e.preventDefault();
        h.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      li.appendChild(a);
      tocList.appendChild(li);
      items.push({ li: li, id: h.id });
    });

    // Active-section tracking via IntersectionObserver
    // root: panel → intersections are relative to the panel's visible area
    let activeId = headings[0] ? headings[0].id : null;

    function setActive(id) {
      if (id === activeId) return;
      activeId = id;
      items.forEach(function (item) {
        if (item.id === activeId) {
          item.li.classList.add('is-active');
        } else {
          item.li.classList.remove('is-active');
        }
      });
    }

    // Initialise first item as active
    if (items.length) items[0].li.classList.add('is-active');

    const observer = new IntersectionObserver(
      function (entries) {
        // Pick the top-most intersecting heading
        const intersecting = entries
          .filter(function (e) { return e.isIntersecting; })
          .sort(function (a, b) { return a.boundingClientRect.top - b.boundingClientRect.top; });

        if (intersecting.length) {
          setActive(intersecting[0].target.id);
        }
      },
      {
        root: panel,
        // Fire when heading enters top 35% of the panel
        rootMargin: '0px 0px -65% 0px',
        threshold: 0,
      }
    );

    headings.forEach(function (h) { observer.observe(h); });

    // Panel scroll: also track backward scroll (headings leaving bottom)
    const scrollObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            // Heading has scrolled above the panel top — keep it active
            // until the next heading enters
          }
        });
      },
      { root: panel, threshold: 0 }
    );
    headings.forEach(function (h) { scrollObserver.observe(h); });

    // Cleanup on navigation
    document.addEventListener('astro:before-swap', function () {
      observer.disconnect();
      scrollObserver.disconnect();
    }, { once: true });
  }

  // Run on page load (and after Astro client-side transitions)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCaseTOC);
  } else {
    initCaseTOC();
  }
  document.addEventListener('astro:page-load', initCaseTOC);
})();
</script>
