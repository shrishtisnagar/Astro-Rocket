---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import ProjectHero from '@/components/projects/ProjectHero.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { url as assetUrl } from '@/lib/url';

interface Props {
  title: string;
  description: string;
  year?: number;
  client?: string;
  role?: string;
  services?: string[];
  url?: string;
  repo?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageUrl?: string;
  imageAlt?: string;
  related?: CollectionEntry<'projects'>[];
}

const {
  title,
  description,
  year,
  client,
  role,
  services = [],
  url,
  repo,
  tags = [],
  image,
  imageUrl,
  imageAlt,
  related = [],
} = Astro.props;

const ogImage = image?.src || siteConfig.ogImage;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: title },
];
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
>
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showCta={false}
    showScrollProgress
  />

  <div class="min-h-screen pt-16">
    <ProjectHero
      title={title}
      description={description}
      tags={tags}
      year={year}
      client={client}
      role={role}
      services={services}
      url={url}
      repo={repo}
      image={image}
      imageUrl={imageUrl}
      imageAlt={imageAlt}
    />

    <article class="pt-8 pb-[var(--space-section-md)]">
      <div class="mx-auto max-w-4xl px-6">
        <Breadcrumbs items={breadcrumbs} class="mb-8" />

        <div class="prose prose-lg max-w-none" data-reveal-content>
          <slot />
        </div>

        <footer class="border-border mt-12 border-t pt-8" data-reveal>
          <a
            href={assetUrl('/projects')}
            class="text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300 inline-flex items-center gap-2 text-sm font-medium transition-colors"
          >
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Projects
          </a>
        </footer>
      </div>
    </article>

    {related.length > 0 && (
      <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border" data-reveal>
        <div class="mx-auto max-w-4xl px-6">
          <h2 class="font-display text-2xl font-bold text-foreground mb-6">More projects</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((project) => {
              const slug = project.id.replace(/\.mdx?$/, '');
              const hasBody = project.body && project.body.trim().length > 0;
              return (
                <a
                  href={hasBody ? assetUrl(`/projects/${slug}`) : project.data.url}
                  target={hasBody ? undefined : '_blank'}
                  rel={hasBody ? undefined : 'noopener noreferrer'}
                  class="rp-card group block"
                >
                  <div class="rp-card-inner">
                    <div class="rp-img">
                      {project.data.imageUrl && (
                        <img
                          src={project.data.imageUrl.startsWith('/') ? assetUrl(project.data.imageUrl) : project.data.imageUrl}
                          alt={project.data.imageAlt || project.data.title}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                          loading="lazy"
                        />
                      )}
                    </div>
                    <div class="rp-overlay">
                      <p class="rp-description">{project.data.description}</p>
                      <div class="rp-title-row">
                        <h3 class="rp-title">{project.data.title}</h3>
                        <Icon name="arrow-up-right" size="sm" class="rp-arrow" />
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <ContactFooterSection videoBg={assetUrl("/videos/hero-bg.mp4")} videoSpeed={0.825} />
  </div>

  <Footer slot="footer" layout="simple" background="secondary" videoBg={assetUrl("/videos/hero-bg.mp4")} videoSpeed={0.825} />
</BaseLayout>

<style>
  .rp-card-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 1 / 1;
    box-shadow: 0 4px 24px -4px rgba(0,0,0,0.18);
  }

  .rp-img {
    position: absolute;
    inset: 0;
    background: oklch(18% 0.02 344);
  }

  .rp-img img {
    filter: grayscale(100%);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .rp-card:hover .rp-img img {
    filter: grayscale(0%);
  }

  .rp-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 40%, transparent 75%);
    transition: background 0.4s ease;
  }

  .rp-card:hover .rp-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.60) 50%, rgba(0,0,0,0.10) 100%);
  }

  .rp-description {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.80);
    line-height: 1.55;
    margin-bottom: 0.6rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .rp-card:hover .rp-description {
    opacity: 1;
    transform: translateY(0);
  }

  .rp-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .rp-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .rp-arrow {
    color: rgba(255,255,255,0.7);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .rp-card:hover .rp-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .rp-description, .rp-img img { transition: none; }
  }
</style>
