---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import ContactFooterSection from '@/components/layout/ContactFooterSection.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import siteConfig from '@/config/site.config';
import { url as assetUrl } from '@/lib/url';

interface Props {
  title: string;
  description: string;
  year?: number;
  client?: string;
  role?: string;
  services?: string[];
  url?: string;
  repo?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageUrl?: string;
  imageAlt?: string;
  related?: CollectionEntry<'projects'>[];
}

const {
  title,
  description,
  year,
  client,
  role,
  services: _services = [],
  url,
  repo,
  tags = [],
  image,
  imageUrl,
  imageAlt,
  related = [],
} = Astro.props;

const ogImage = image?.src || siteConfig.ogImage;

// Resolve hero image source
const heroImageSrc = image
  ? image.src
  : imageUrl
    ? (imageUrl.startsWith('http') ? imageUrl : assetUrl(imageUrl.startsWith('/') ? imageUrl : `/${imageUrl}`))
    : null;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
>
  <!-- Header: no scroll-progress bar (panel scroll, not window) -->
  <Header
    slot="header"
    position="fixed"
    shape="bar"
    variant="solid"
    size="lg"
    showCta={false}
    showScrollProgress={false}
  />

  <!-- ╔════════════════════════════════════════════╗
       ║  TWO-PANE CASE STUDY SHELL                ║
       ║  Left: fixed identity + TOC               ║
       ║  Right: scrollable cinematic content      ║
       ╚════════════════════════════════════════════╝ -->
  <div class="cs-shell" id="cs-shell">

    <!-- ══════════ LEFT SIDEBAR ══════════ -->
    <aside class="cs-sidebar" id="cs-sidebar" aria-label="Case study navigation">
      <div class="cs-sidebar-inner">

        <!-- Back navigation -->
        <a href={assetUrl('/projects')} class="cs-back">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
            viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          All projects
        </a>

        <!-- Project identity -->
        <div class="cs-identity">
          {tags.length > 0 && (
            <div class="cs-id-tags">
              {tags.map((tag) => (
                <span class="cs-id-tag">{tag}</span>
              ))}
            </div>
          )}
          <h2 class="cs-id-title">{title}</h2>
          {description && (
            <p class="cs-id-desc">{description}</p>
          )}
        </div>

        <!-- Meta grid -->
        {(year || client || role) && (
          <dl class="cs-meta">
            {year && (
              <>
                <dt class="cs-meta-label">Year</dt>
                <dd class="cs-meta-value">{year}</dd>
              </>
            )}
            {client && (
              <>
                <dt class="cs-meta-label">Client</dt>
                <dd class="cs-meta-value">{client}</dd>
              </>
            )}
            {role && (
              <>
                <dt class="cs-meta-label">Role</dt>
                <dd class="cs-meta-value">{role}</dd>
              </>
            )}
          </dl>
        )}

        <!-- External CTA -->
        {url && (
          <a href={url} target="_blank" rel="noopener noreferrer" class="cs-id-cta">
            View case study
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}
        {repo && (
          <a href={repo} target="_blank" rel="noopener noreferrer" class="cs-id-cta cs-id-cta--secondary">
            View source
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </a>
        )}

        <!-- Project image fills the remaining sidebar space -->
        {heroImageSrc && (
          <div class="cs-sidebar-image">
            <img
              src={heroImageSrc}
              alt={imageAlt || title}
              class="cs-sidebar-img"
              loading="eager"
              decoding="async"
            />
          </div>
        )}

      </div>
    </aside>

    <!-- ══════════ RIGHT PANEL (scrolls) ══════════ -->
    <div class="cs-panel" id="cs-panel">

      <!-- ─── Hero banner: cover image as atmospheric backdrop ─── -->
      {heroImageSrc && (
        <div class="cs-hero" aria-hidden="true">
          <img
            src={heroImageSrc}
            alt=""
            class="cs-hero-img"
            loading="eager"
            decoding="async"
          />
          <div class="cs-hero-gradient"></div>
        </div>
      )}

      <!-- ─── Intro: PROBLEM + OBJECTIVE side-by-side cards ─── -->
      <div class="cs-intro" id="cs-intro">
        <div class="cs-intro-card" id="cs-intro-problem">
          <div class="cs-intro-card-label">Problem</div>
          <div class="cs-intro-card-body" id="cs-intro-problem-body"></div>
        </div>
        <div class="cs-intro-card" id="cs-intro-objective">
          <div class="cs-intro-card-label">Objective</div>
          <div class="cs-intro-card-body" id="cs-intro-objective-body"></div>
        </div>
      </div>

      <!-- ─── Article prose ─── -->
      <article class="cs-article" id="cs-article">
        <div class="prose prose-lg dark:prose-invert">
          <slot />
        </div>

        <div class="cs-article-footer" data-reveal>
          <a href={assetUrl('/projects')} class="cs-back-inline">
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Projects
          </a>
        </div>
      </article>

    </div><!-- /cs-panel -->
  </div><!-- /cs-shell -->

  <!-- ══ Normal document flow: scrolled to after the shell ══ -->
  {related.length > 0 && (
    <section class="cs-related" data-reveal>
      <div class="cs-related-inner">
        <h2 class="cs-related-title">More projects</h2>
        <div class="cs-related-grid">
          {related.map((project) => {
            const slug = project.id.replace(/\.mdx?$/, '');
            const hasBody = project.body && project.body.trim().length > 0;
            return (
              <a
                href={hasBody ? assetUrl(`/projects/${slug}`) : project.data.url}
                target={hasBody ? undefined : '_blank'}
                rel={hasBody ? undefined : 'noopener noreferrer'}
                class="rp-card group block"
              >
                <div class="rp-card-inner">
                  <div class="rp-img">
                    {project.data.imageUrl && (
                      <img
                        src={project.data.imageUrl.startsWith('/') ? assetUrl(project.data.imageUrl) : project.data.imageUrl}
                        alt={project.data.imageAlt || project.data.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                      />
                    )}
                  </div>
                  <div class="rp-overlay">
                    <div class="rp-title-row">
                      <h3 class="rp-title">{project.data.title}</h3>
                      <Icon name="arrow-up-right" size="sm" class="rp-arrow" />
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <ContactFooterSection
    videoBg={assetUrl("/videos/hero-bg.mp4")}
    videoSpeed={0.825}
  />
</BaseLayout>

<!-- ════════════════════════════════════════════════════════
     STYLES
     ════════════════════════════════════════════════════════ -->
<style>
  /* ── CSS variables ── */
  :root {
    --cs-header-h: 4rem;    /* must match Header size="lg" (h-16) */
    --cs-sidebar-w: 300px;
  }

  /* Hide default back-to-top on case study pages */
  :global(#back-to-top) {
    display: none !important;
  }

  /* ════════════════════════
     TWO-PANE SHELL
     ════════════════════════ */
  .cs-shell {
    display: flex;
    height: calc(100dvh - var(--cs-header-h));
    margin-top: var(--cs-header-h);
    overflow: hidden;
    position: relative;
  }

  /* ════════════════════════
     LEFT SIDEBAR
     ════════════════════════ */
  .cs-sidebar {
    width: var(--cs-sidebar-w);
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    border-right: 1px solid var(--color-border);
    background: var(--color-background);
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .cs-sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.75rem 1.375rem 3rem;
    min-height: 100%;
  }

  /* Back link */
  .cs-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back:hover {
    color: var(--color-foreground-muted);
  }

  /* Identity block */
  .cs-identity {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cs-id-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .cs-id-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: var(--color-brand-100);
    color: var(--color-brand-700);
  }
  :global(.dark) .cs-id-tag {
    background: color-mix(in oklch, var(--color-brand-900) 45%, transparent);
    color: var(--color-brand-300);
  }

  .cs-id-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-foreground);
    margin: 0;
  }

  .cs-id-desc {
    font-size: 0.7875rem;
    line-height: 1.65;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* Meta key-value grid */
  .cs-meta {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 0.75rem;
    row-gap: 0.325rem;
    align-items: baseline;
    margin: 0;
  }
  .cs-meta-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--color-foreground-subtle);
  }
  .cs-meta-value {
    font-size: 0.8rem;
    color: var(--color-foreground-muted);
    margin: 0;
  }

  /* CTA buttons */
  .cs-id-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .cs-id-cta:hover {
    color: var(--color-brand-500);
    gap: 0.55rem;
  }
  .cs-id-cta--secondary {
    color: var(--color-foreground-muted);
  }
  .cs-id-cta--secondary:hover {
    color: var(--color-foreground);
  }
  :global(.dark) .cs-id-cta {
    color: var(--color-brand-400);
  }
  :global(.dark) .cs-id-cta:hover {
    color: var(--color-brand-300);
  }

  /* ── Sidebar image ── */
  .cs-sidebar-image {
    /* Use position:relative + absolute child so height never depends
       on a percentage resolution chain through flex min-height */
    position: relative;
    flex: 1;
    min-height: 200px;
    overflow: hidden;
    border-radius: 0.75rem;
    margin-top: auto;
  }

  .cs-sidebar-img {
    /* Fill the container absolutely — robust regardless of whether
       the parent's height is definite from flex or from min-height */
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .cs-sidebar:hover .cs-sidebar-img {
    transform: scale(1.03);
  }

  /* ════════════════════════
     RIGHT PANEL
     ════════════════════════ */
  .cs-panel {
    flex: 1;
    min-width: 0;
    height: 100%;
    overflow-y: scroll;
    overflow-x: hidden;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  /* ════════════════════════
     HERO BANNER
     ════════════════════════ */
  .cs-hero {
    position: relative;
    width: 100%;
    height: clamp(220px, 38vh, 420px);
    overflow: hidden;
    background: oklch(8% 0.015 250); /* deep dark fallback when no image */
    flex-shrink: 0;
  }

  .cs-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Heavy blur turns any screenshot into an atmospheric colour wash —
       scale(1.12) hides the blur edge artefacts */
    filter: blur(18px) brightness(0.32) saturate(1.5);
    transform: scale(1.12);
    will-change: filter;
  }

  .cs-hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(0, 0, 0, 0.55) 70%,
      rgba(0, 0, 0, 0.90) 100%
    );
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-hero-img { transition: none; }
  }

  /* ════════════════════════
     INTRO CARDS
     ════════════════════════ */
  .cs-intro {
    display: none; /* shown as flex by JS when content is found */
    border-bottom: 1px solid var(--color-border);
  }

  .cs-intro.is-ready {
    display: flex;
  }

  .cs-intro-card {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: clamp(2rem, 5vw, 3.5rem);
    padding-top: clamp(3.75rem, 7vw, 5rem); /* room for the top label */
    background: var(--color-background);
    position: relative;
  }

  /* Section label pinned to top */
  .cs-intro-card-label {
    position: absolute;
    top: clamp(1.5rem, 3.5vw, 2rem);
    left: clamp(2rem, 5vw, 3.5rem);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-brand-500);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cs-intro-card-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    flex-shrink: 0;
  }

  :global(.dark) .cs-intro-card-label {
    color: var(--color-brand-400);
  }

  /* Content block */
  .cs-intro-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cs-intro-card-body :global(p) {
    color: var(--color-foreground-muted);
    font-size: clamp(0.875rem, 1.3vw, 1rem);
    line-height: 1.85;
    margin: 0;
  }

  .cs-intro-card-body :global(ul),
  .cs-intro-card-body :global(ol) {
    color: var(--color-foreground-muted);
    font-size: clamp(0.8125rem, 1.2vw, 0.9375rem);
    line-height: 1.75;
    margin: 0;
    padding-left: 1.375rem;
  }

  .cs-intro-card-body :global(li) {
    margin-bottom: 0.35rem;
  }

  .cs-intro-card-body :global(strong) {
    color: var(--color-foreground);
    font-weight: 600;
  }

  /* ════════════════════════
     ARTICLE
     ════════════════════════ */
  .cs-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
  }

  /* ── Prose content overrides ── */

  /* Fix 1: width — prose defaults to ~65ch; .cs-article centres it */

  /* Fix 2: h2 section headings → calm editorial chapter markers */
  .cs-article :global(.prose h2) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-foreground);
    margin-top: 3rem;
    margin-bottom: 0.875rem;
  }
  :global(.dark) .cs-article :global(.prose h2) {
    color: #fff;
  }

  /* h3 gets a quieter version */
  .cs-article :global(.prose h3) {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  /* Fix 3: images — rounded corners, visible ring + shadow on dark bg */
  .cs-article :global(.prose img) {
    border-radius: 0.75rem;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12),
      0 4px 6px -2px rgba(0, 0, 0, 0.5),
      0 12px 40px -4px rgba(0, 0, 0, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.10);
    display: block;
    max-width: 100%;
    height: auto;
    opacity: 1 !important; /* override any reveal-system opacity */
    margin-left: auto;
    margin-right: auto;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  /* Fix 4 (reading strain): slightly off-white body text + more air */
  .cs-article :global(.prose p),
  .cs-article :global(.prose li) {
    color: rgba(255, 255, 255, 0.80);
    line-height: 1.9;
  }

  .cs-article :global(.prose strong) {
    color: rgba(255, 255, 255, 0.95);
  }

  /* Fix 4: stat tables — distinct background, bold header row */
  .cs-article :global(.prose table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 0.625rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin-top: 1.75rem;
    margin-bottom: 1.75rem;
    font-size: 0.875rem;
  }

  .cs-article :global(.prose thead) {
    background: oklch(22% 0.04 280);
  }

  .cs-article :global(.prose thead th) {
    padding: 0.75rem 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-400);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: left;
  }

  .cs-article :global(.prose tbody tr) {
    background: oklch(14% 0.01 270);
    transition: background 0.15s ease;
  }

  .cs-article :global(.prose tbody tr:hover) {
    background: oklch(18% 0.03 280);
  }

  .cs-article :global(.prose tbody tr:nth-child(even)) {
    background: oklch(16% 0.015 270);
  }

  .cs-article :global(.prose tbody td) {
    padding: 0.625rem 1rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-foreground-muted);
    vertical-align: middle;
  }

  .cs-article :global(.prose tbody td:first-child) {
    font-weight: 500;
    color: var(--color-foreground);
  }

  /* Column separators */
  .cs-article :global(.prose th:not(:last-child)),
  .cs-article :global(.prose td:not(:last-child)) {
    border-right: 1px solid var(--color-border);
  }

  .cs-article-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding-top: 2rem;
  }

  .cs-back-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-brand-600);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .cs-back-inline:hover { color: var(--color-brand-500); }
  :global(.dark) .cs-back-inline { color: var(--color-brand-400); }
  :global(.dark) .cs-back-inline:hover { color: var(--color-brand-300); }

  /* ════════════════════════
     RELATED PROJECTS
     ════════════════════════ */
  .cs-related {
    border-top: 1px solid var(--color-border);
    background: var(--color-background-secondary);
    padding: 3rem 2rem;
  }

  .cs-related-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .cs-related-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin: 0 0 1.375rem;
  }

  .cs-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  /* ── Related card styles (same design as projects page) ── */
  .rp-card-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 1 / 1;
    box-shadow: 0 4px 24px -4px rgba(0, 0, 0, 0.18);
  }

  .rp-img {
    position: absolute;
    inset: 0;
    background: oklch(18% 0.02 344);
  }

  .rp-img img {
    filter: grayscale(100%);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .rp-card:hover .rp-img img {
    filter: grayscale(0%);
  }

  .rp-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.125rem;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 40%, transparent 75%);
    transition: background 0.4s ease;
  }

  .rp-card:hover .rp-overlay {
    background: linear-gradient(to top, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.60) 50%, rgba(0,0,0,0.10) 100%);
  }

  .rp-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .rp-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .rp-arrow {
    color: rgba(255, 255, 255, 0.65);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .rp-card:hover .rp-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  /* ════════════════════════
     RESPONSIVE
     ════════════════════════ */

  /* Tablet: narrower sidebar */
  @media (min-width: 768px) and (max-width: 1100px) {
    :root { --cs-sidebar-w: 240px; }
    .cs-id-desc { display: none; } /* reclaim space on tight tablets */
    .cs-related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile: stack vertically, sidebar above content */
  @media (max-width: 767px) {
    .cs-shell {
      flex-direction: column;
      height: auto;
      overflow: visible;
      margin-top: var(--cs-header-h);
    }

    .cs-sidebar {
      width: 100%;
      height: auto;
      overflow: visible;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .cs-sidebar-inner {
      padding: 1.25rem 1.25rem 1.5rem;
    }

    .cs-panel {
      height: auto;
      overflow: visible;
    }

    .cs-intro.is-ready {
      flex-direction: column;
    }

    .cs-intro-card {
      padding: 3.5rem 1.5rem 2rem;
    }

    .cs-intro-card + .cs-intro-card {
      border-top: 1px solid var(--color-border);
    }

    .cs-article {
      padding: 2.5rem 1.25rem 2rem;
    }

    .cs-related {
      padding: 2rem 1.25rem;
    }

    .cs-related-grid {
      grid-template-columns: 1fr;
    }
  }


  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cs-scroll-hint-icon {
      animation: none;
    }
    .rp-img img {
      transition: none;
    }
  }
</style>

<script is:inline>
(function () {
  'use strict';

  // Meta line prefixes rendered as bold paragraphs at the top of prose.
  // These repeat information already visible in the sidebar, so we hide them.
  const META_PREFIXES = [
    'PLATFORM:', 'ACCOUNT TYPE:', 'CAMPAIGN TYPE:', 'OBJECTIVE:',
    'CLIENT:', 'INDUSTRY:', 'SECTOR:', 'TOOL:', 'TOOLS:',
  ];

  const PROBLEM_KEYS = ['PROBLEM', 'CHALLENGE'];
  const OBJECTIVE_KEYS = ['OBJECTIVE', 'GOAL', 'GOALS'];

  function cleanText(el) {
    return el.textContent.replace(/[*_#:`]/g, '').trim().toUpperCase();
  }

  function extractSection(h2) {
    // Returns [h2, ...siblings] until the next h2
    const members = [h2];
    let cursor = h2.nextElementSibling;
    while (cursor && cursor.tagName !== 'H2') {
      members.push(cursor);
      cursor = cursor.nextElementSibling;
    }
    return members;
  }

  function findSectionH2(h2s, keys) {
    for (let i = 0; i < h2s.length; i++) {
      const t = cleanText(h2s[i]);
      if (keys.some((k) => t.includes(k))) return h2s[i];
    }
    return null;
  }

  function liftIntoCard(h2, cardBody) {
    if (!h2 || !cardBody) return false;
    const members = extractSection(h2);
    let moved = false;
    members.forEach((el, i) => {
      if (i === 0) {
        // hide the h2 from prose — the card already has a label
        el.style.display = 'none';
      } else {
        cardBody.appendChild(el.cloneNode(true));
        el.style.display = 'none';
        moved = true;
      }
    });
    return moved;
  }

  function initIntroCards() {
    const article = document.getElementById('cs-article');
    if (!article) return;
    const prose = article.querySelector('.prose');
    if (!prose) return;

    // ── 1. Hide metadata bold-paragraph lines at the very top of prose
    let node = prose.firstElementChild;
    while (node && node.tagName === 'P') {
      const isStrongOnly =
        node.children.length === 1 &&
        node.children[0].tagName === 'STRONG' &&
        node.textContent.trim() === node.children[0].textContent.trim();
      if (!isStrongOnly) break;
      const upper = node.textContent.trim().toUpperCase();
      if (META_PREFIXES.some((p) => upper.startsWith(p))) {
        node.style.display = 'none';
        node = node.nextElementSibling;
      } else {
        break;
      }
    }

    // ── 2. Lift PROBLEM and OBJECTIVE into intro cards
    const h2s = Array.prototype.slice.call(prose.querySelectorAll('h2'));
    const problemH2   = findSectionH2(h2s, PROBLEM_KEYS);
    const objectiveH2 = findSectionH2(h2s, OBJECTIVE_KEYS);

    const problemBody   = document.getElementById('cs-intro-problem-body');
    const objectiveBody = document.getElementById('cs-intro-objective-body');

    const hadProblem   = liftIntoCard(problemH2,   problemBody);
    const hadObjective = liftIntoCard(objectiveH2, objectiveBody);

    // ── 3. Show the intro section if at least one card has content
    if (hadProblem || hadObjective) {
      const intro = document.getElementById('cs-intro');
      if (intro) intro.classList.add('is-ready');
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIntroCards);
  } else {
    initIntroCards();
  }
  document.addEventListener('astro:page-load', initIntroCards);
})();
</script>

