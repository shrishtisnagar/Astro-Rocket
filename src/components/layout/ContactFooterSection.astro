---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'calendar',
    label: 'Book a call',
    value: 'calendly.com/shrishtisnagar',
    href: 'https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti',
    external: true,
  },
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    href: link.href,
    external: true,
  })),
];
---

<div class="contact-footer-inner">
  <div class="mx-auto max-w-5xl px-6 pt-6 pb-0">

    <div class="mb-4 flex items-start justify-between gap-4">
      <div>
        <h2 class="font-display text-2xl font-bold text-foreground mb-1">
          Send me a <span class="text-brand-500">message.</span>
        </h2>
        <p class="text-sm text-foreground-muted">Use the form below or reach out directly. I'll get back to you within 1 business day.</p>
      </div>
      <!-- Icon-only channel buttons -->
      <div class="flex items-center gap-2 shrink-0 mt-1">
        {channels.map((ch) => (
          <a
            href={ch.href}
            aria-label={ch.label}
            {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            class="contact-icon-btn"
          >
            <Icon name={ch.icon} size="sm" />
          </a>
        ))}
      </div>
    </div>

    <!-- Contact form full-width -->
    <Card padding="md" class="flex flex-col justify-center">
      <ContactForm compact class="space-y-3" />
    </Card>
  </div>
</div>

<style>
  .contact-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;       /* 32px */
    height: 2rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-foreground-muted);
    background: transparent;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
    flex-shrink: 0;
  }

  .contact-icon-btn:hover {
    color: var(--color-brand-500);
    border-color: var(--color-brand-500);
    background: color-mix(in oklch, var(--color-brand-500) 10%, transparent);
  }
</style>
