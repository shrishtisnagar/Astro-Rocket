---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

interface Props {
  /** Path to a looping background video (e.g. "/videos/hero-bg.mp4") */
  videoBg?: string;
  /** Playback rate for the background video (default 0.75) */
  videoSpeed?: number;
}

const { videoBg, videoSpeed = 0.75 } = Astro.props;

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'calendar',
    label: 'Book a call',
    value: 'calendly.com/shrishtisnagar',
    href: 'https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti',
    external: true,
  },
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    href: link.href,
    external: true,
  })),
];
---

<section class="contact-footer-section pt-7 pb-7">
  {videoBg && (
    <div class="video-bg-wrap" aria-hidden="true">
      <video
        class="video-bg"
        src={videoBg}
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        data-speed={videoSpeed}
      />
      <div class="video-overlay" />
    </div>
  )}
  <div class="mx-auto max-w-5xl px-6" style="position:relative;z-index:1;">

    <div class="mb-4">
      <h2 class="font-display text-2xl font-bold text-foreground mb-1">
        Send me a <span class="text-brand-500">message.</span>
      </h2>
      <p class="text-sm text-foreground-muted">Use the form below or reach out on any of these channels. I'll get back to you within 1 business day.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-10 items-start">

      <!-- Left: contact form -->
      <div class="lg:col-span-3">
        <Card padding="md" class="flex flex-col justify-center">
          <h3 class="font-display text-base font-bold text-foreground mb-4">Send a message</h3>
          <ContactForm compact class="space-y-3" />
        </Card>
      </div>

      <!-- Right: channels + location -->
      <div class="lg:col-span-2 space-y-3">
        <div>
          <h3 class="font-display text-sm font-bold text-foreground mb-0.5">Other channels</h3>
          <p class="text-xs text-foreground-muted">Prefer a direct channel? Pick whichever works best.</p>
        </div>

        <div class="space-y-2">
          {channels.map((ch) => (
            <a
              href={ch.href}
              {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
              class="block group"
            >
              <Card hover padding="sm" class="h-full">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 shrink-0 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                    <Icon name={ch.icon} size="sm" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-xs text-foreground">{ch.label}</p>
                    <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                  </div>
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                </div>
              </Card>
            </a>
          ))}
        </div>

        <Card hover padding="sm" class="bg-brand-500/5 border-brand-500/20">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 shrink-0 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="map-pin" size="sm" />
            </div>
            <div>
              <p class="font-semibold text-xs text-foreground">{siteConfig.address?.city ?? 'Your City'}</p>
              <p class="text-xs text-foreground-muted mt-0.5">Based in {siteConfig.address?.country ?? 'Your Country'}</p>
            </div>
          </div>
        </Card>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-footer-section {
    position: relative;
    overflow: hidden;
  }

  /* ── Video background ───────────────────────────────────── */
  .video-bg-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    /* Hide video in light mode */
    display: none;
  }

  :global(.dark) .video-bg-wrap {
    display: block;
  }

  .video-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 1s ease;
    filter: saturate(70%) hue-rotate(130deg) brightness(0.55) contrast(1.10);
  }

  .video-bg.is-loaded { opacity: 1; }

  .video-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, var(--color-background) 0%, transparent 30%),
      radial-gradient(ellipse at 30% 40%, oklch(28% 0.10 344 / 0.60) 0%, oklch(8% 0.04 344 / 0.80) 100%);
    mix-blend-mode: multiply;
  }
</style>

<script is:inline>
  (function () {
    function initContactSectionVideoBg() {
      document.querySelectorAll('.contact-footer-section .video-bg').forEach(function (v) {
        const speed = parseFloat(v.getAttribute('data-speed') || '0.75');
        if (!isNaN(speed) && speed > 0) v.playbackRate = speed;

        if (v.readyState >= 3) {
          v.classList.add('is-loaded');
        } else {
          v.addEventListener('canplay', function () { v.classList.add('is-loaded'); }, { once: true });
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactSectionVideoBg);
    } else {
      initContactSectionVideoBg();
    }
  })();
</script>
