---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import ContactForm from '@/components/patterns/ContactForm.astro';
import siteConfig from '@/config/site.config';
import { resolveSocialLinks } from '@/lib/utils';

const socialLinks = resolveSocialLinks(siteConfig.socialLinks);

const channels = [
  {
    icon: 'calendar',
    label: 'Book a call',
    value: 'calendly.com/shrishtisnagar',
    href: 'https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti',
    external: true,
  },
  {
    icon: 'mail',
    label: 'Email',
    value: siteConfig.email,
    href: `mailto:${siteConfig.email}`,
    external: false,
  },
  ...socialLinks.map((link) => ({
    icon: link.icon,
    label: link.label,
    value: link.href.replace(/^https?:\/\/(www\.)?/, ''),
    href: link.href,
    external: true,
  })),
];
---

<section class="bg-background pt-[var(--space-section-md)] pb-0">
  <div class="mx-auto max-w-5xl px-6">

    <div class="mb-10">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
        Send me a <span class="text-brand-500">message.</span>
      </h2>
      <p class="text-foreground-muted">Use the form below or reach out on any of these channels. I'll get back to you within 1 business day.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-stretch">

      <!-- Left: contact form -->
      <div class="lg:col-span-3 h-full">
        <Card padding="lg" class="h-full flex flex-col justify-center">
          <h3 class="font-display text-xl font-bold text-foreground mb-6">Send a message</h3>
          <ContactForm />
        </Card>
      </div>

      <!-- Right: channels + location -->
      <div class="lg:col-span-2 space-y-4">
        <div>
          <h3 class="font-display text-lg font-bold text-foreground mb-1">Other channels</h3>
          <p class="text-sm text-foreground-muted">Prefer a direct channel? Pick whichever works best.</p>
        </div>

        <div class="space-y-2">
          {channels.map((ch) => (
            <a
              href={ch.href}
              {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
              class="block group"
            >
              <Card hover padding="sm" class="h-full">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                    <Icon name={ch.icon} size="sm" />
                  </div>
                  <div class="min-w-0 flex-1">
                    <p class="font-semibold text-sm text-foreground">{ch.label}</p>
                    <p class="text-xs text-foreground-muted truncate">{ch.value}</p>
                  </div>
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                </div>
              </Card>
            </a>
          ))}
        </div>

        <Card hover padding="sm" class="bg-brand-500/5 border-brand-500/20">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="map-pin" size="sm" />
            </div>
            <div>
              <p class="font-semibold text-sm text-foreground">{siteConfig.address?.city ?? 'Your City'}</p>
              <p class="text-xs text-foreground-muted mt-0.5">Based in {siteConfig.address?.country ?? 'Your Country'}</p>
            </div>
          </div>
        </Card>
      </div>

    </div>
  </div>
</section>
