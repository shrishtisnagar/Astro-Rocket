---
interface Testimonial {
  quote: string;
  author: string;
  handle: string;
  title: string;
  platform: 'linkedin' | 'twitter' | 'topmate';
  avatar: string;
  row: number;
  order: number;
}

const mdFiles = import.meta.glob('/src/content/testimonials/*.md', { eager: true });
const all: Testimonial[] = Object.values(mdFiles).map((f: any) => f.frontmatter as Testimonial);

const row1 = all.filter((t) => t.row === 1).sort((a, b) => a.order - b.order);
const row2 = all.filter((t) => t.row === 2).sort((a, b) => a.order - b.order);
---

<section class="testimonials-section">
  {[{ items: row1, dir: 'left' }, { items: row2, dir: 'right' }].map(({ items, dir }) => (
    <div class="marquee-track" data-dir={dir}>
      <div class={`marquee-inner marquee-${dir}`}>
        {[...items, ...items].map((t) => (
          <div class="testimonial-card">
            <div class="card-header">
              <div class="card-author">
                {t.avatar ? (
                  <img src={t.avatar} alt={t.author} class="avatar" />
                ) : (
                  <div class="avatar-fallback">{t.author.charAt(0).toUpperCase()}</div>
                )}
                <div class="author-info">
                  <span class="author-name">{t.author}</span>
                  <span class="author-meta">{t.title}</span>
                </div>
              </div>
            </div>
            <p class="card-quote">"{t.quote}"</p>
            <span class="card-handle">{t.handle}</span>
          </div>
        ))}
      </div>
    </div>
  ))}
</section>

<style>
  .testimonials-section {
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 3rem 0;
  }

  .marquee-track {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .marquee-inner {
    display: flex;
    gap: 1rem;
    width: max-content;
  }

  .marquee-left {
    animation: scroll-left 40s linear infinite;
  }

  .marquee-right {
    animation: scroll-right 40s linear infinite;
  }

  .marquee-track:hover .marquee-left,
  .marquee-track:hover .marquee-right {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scroll-right {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .testimonial-card {
    flex-shrink: 0;
    width: 320px;
    background: #1a0d12;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .card-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .avatar-fallback {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.75);
    font-weight: 700;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.2;
  }

  .author-meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.3;
  }

.card-quote {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.6;
    margin: 0;
  }

  .card-handle {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-left,
    .marquee-right {
      animation: none;
    }
  }
</style>
