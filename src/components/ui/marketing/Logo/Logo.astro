---
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';
import { url } from '@/lib/url';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  forceDark?: boolean;
  variant?: 'logomark' | 'full';
  class?: string;
  letter?: string;
}

const { size = 'md', class: className, letter: letterProp } = Astro.props;

const sizeClasses: Record<string, { box: string; text: string; radius: string; img: string }> = {
  sm:    { box: 'w-5 h-5',   text: 'text-[14px]', radius: 'rounded-[4px]', img: 'h-5'  },
  md:    { box: 'w-6 h-6',   text: 'text-[16px]', radius: 'rounded-[5px]', img: 'h-6'  },
  lg:    { box: 'w-8 h-8',   text: 'text-[22px]', radius: 'rounded-[6px]', img: 'h-8'  },
  xl:    { box: 'w-12 h-12', text: 'text-[34px]', radius: 'rounded-[8px]', img: 'h-12' },
  '2xl': { box: 'w-24 h-24', text: 'text-[68px]', radius: 'rounded-[14px]',img: 'h-24' },
};

const { box, text, radius, img } = sizeClasses[size] ?? sizeClasses.md;
const letter = letterProp ?? siteConfig.name.charAt(0).toUpperCase();
const imageUrl = siteConfig.branding.logo.imageUrl;
const showImage = !!imageUrl && !imageUrl.includes('favicon');
const resolvedImageUrl = showImage ? url(imageUrl!) : '';
---

{showImage ? (
  <img
    src={resolvedImageUrl}
    alt={siteConfig.branding.logo.alt}
    class={cn(img, 'w-auto object-contain shrink-0', className)}
    aria-label={siteConfig.branding.logo.alt}
  />
) : (
  <span
    class={cn(
      'inline-flex items-center justify-center shrink-0',
      'text-white',
      'font-display font-bold leading-none select-none',
      box, text, radius,
      className
    )}
    style="background-color: #210017"
    aria-label={siteConfig.branding.logo.alt}
    role="img"
  >
    {letter}
  </span>
)}
