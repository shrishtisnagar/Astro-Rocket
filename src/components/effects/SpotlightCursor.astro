---
/**
 * SpotlightCursor
 * Small precise dot at exact cursor + large lagging glow behind it.
 * Glow expands on hover. Desktop / fine pointer only.
 */
---

<!-- Precise dot — follows exactly, no lag -->
<div id="cursor-dot" aria-hidden="true"></div>

<!-- Lagging ambient glow -->
<div id="cursor-spotlight" aria-hidden="true"></div>

<style>
  @media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce) {
    #cursor-dot, #cursor-spotlight { display: none !important; }
  }

  /* Precise dot */
  #cursor-dot {
    position: fixed;
    top: 0; left: 0;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: oklch(70% 0.18 344);
    pointer-events: none;
    z-index: 9999;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s ease, transform 0.15s ease, width 0.2s ease, height 0.2s ease, background 0.2s ease;
    will-change: transform, left, top;
  }

  #cursor-dot.is-visible { opacity: 1; }

  #cursor-dot.is-hovering {
    width: 12px; height: 12px;
    background: oklch(80% 0.20 344);
    transform: translate(-50%, -50%) scale(1.4);
  }

  /* Ambient spotlight glow */
  #cursor-spotlight {
    position: fixed;
    top: 0; left: 0;
    width: 380px; height: 380px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9997;
    opacity: 0;
    background: radial-gradient(
      circle,
      oklch(58% 0.18 344 / 0.14) 0%,
      oklch(45% 0.14 338 / 0.07) 40%,
      transparent 70%
    );
    transform: translate(-50%, -50%);
    transition:
      opacity 0.5s ease,
      width 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.3s ease;
    will-change: left, top, width, height;
  }

  #cursor-spotlight.is-visible { opacity: 1; }

  #cursor-spotlight.is-hovering {
    width: 520px; height: 520px;
    background: radial-gradient(
      circle,
      oklch(62% 0.20 344 / 0.20) 0%,
      oklch(50% 0.16 338 / 0.10) 40%,
      transparent 70%
    );
  }

  /* Hide native cursor on desktop */
  @media (hover: hover) and (pointer: fine) {
    :global(body) { cursor: none; }
    :global(a), :global(button), :global([role="button"]),
    :global(input), :global(textarea), :global(select),
    :global(summary), :global(label[for]) { cursor: none; }
  }
</style>

<script is:inline>
(function () {
  if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const dot = document.getElementById('cursor-dot');
  const glow = document.getElementById('cursor-spotlight');
  if (!dot || !glow) return;

  const INTERACTIVE = 'a, button, [role="button"], input:not([type="hidden"]), textarea, select, summary, label[for]';
  const LERP = 0.1;

  let tx = -200, ty = -200;
  let cx = tx, cy = ty;

  function onMove(e) {
    tx = e.clientX; ty = e.clientY;
    dot.style.left = tx + 'px';
    dot.style.top  = ty + 'px';
    dot.classList.add('is-visible');
    glow.classList.add('is-visible');
  }

  function onLeave() {
    dot.classList.remove('is-visible');
    glow.classList.remove('is-visible');
  }

  function syncHover(e) {
    const target = e.target && e.target.closest ? e.target.closest(INTERACTIVE) : null;
    dot.classList.toggle('is-hovering', !!target);
    glow.classList.toggle('is-hovering', !!target);
  }

  function tick() {
    cx += (tx - cx) * LERP;
    cy += (ty - cy) * LERP;
    glow.style.left = cx + 'px';
    glow.style.top  = cy + 'px';
    requestAnimationFrame(tick);
  }

  document.addEventListener('mousemove', onMove);
  document.addEventListener('mouseleave', onLeave);
  document.addEventListener('mouseover', syncHover);
  requestAnimationFrame(tick);
})();
</script>
