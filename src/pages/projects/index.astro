---
/**
 * Projects page
 * URL: /projects
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import ToolMarquee from '@/components/landing/ToolMarquee.astro';
import { getCollection } from 'astro:content';
import { url } from '@/lib/url';

const projectItems = await getCollection('projects', ({ data }) => !data.draft && data.featured);
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const allProjects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---

<LandingLayout
  title="Projects — The S Curve"
  description="Selected work — marketing strategy, content, and growth engagements."
  showContactFooter={true}
>
  <Hero layout="split" size="xl" class="hero-dark-gradient" showScrollIndicator videoBg={url("/videos/hero-bg.mp4")}>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-300">Available for consulting &amp; projects</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">I'm Shrishti,</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] !text-2xl md:!text-3xl lg:!text-3xl !font-semibold !leading-snug">Marketer + Business Strategist</span>
    </h1>

    <p slot="description">
      I solve messy marketing problems across systems, positioning, and growth.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer">
        Book a call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href={url("/contact")}>
        <Icon name="mail" size="sm" />
        Contact me
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div slot="aside" class="flex items-center justify-center lg:justify-end">
      <div class="hero-photo-wrap">
        <div class="absolute inset-0 rounded-2xl bg-brand-500/15 blur-3xl scale-90" aria-hidden="true"></div>
        <img
          src={url("/images/photo.png")}
          alt="Shrishti S Nagar"
          width="400"
          height="400"
          class="hero-photo"
        />
      </div>
    </div>
  </Hero>

  <!-- Brands -->
  <section class="relative z-10 py-12 bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <div class="flex items-center gap-4" data-reveal>
        <div class="h-px flex-1 bg-border/50"></div>
        <p class="text-xs font-medium uppercase tracking-widest text-foreground-muted">Across industries and markets</p>
        <div class="h-px flex-1 bg-border/50"></div>
      </div>

      <div class="brand-marquee-track">
        <div class="brand-marquee-inner">
          {[
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
          ].map(({ src, alt }) => (
            <div class="brand-logo-item">
              <img src={src} alt={alt} height="40" loading="lazy" draggable="false" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div data-reveal>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Projects I'm Proud of
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {featuredProjects.map((project) => {
          const slug = project.id.replace(/\.mdx?$/, '');
          const hasBody = project.body && project.body.trim().length > 0;
          return (
          <a
            href={hasBody ? url(`/projects/${slug}`) : project.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block h-full"
            data-reveal
          >
            <Card variant="elevated" hover padding="none" class="flex flex-col overflow-hidden h-full">
              {project.data.imageUrl && (
                <div class="case-img-wrap overflow-hidden h-44 shrink-0">
                  <img
                    src={project.data.imageUrl.startsWith('/') ? url(project.data.imageUrl) : project.data.imageUrl}
                    alt={project.data.imageAlt || project.data.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex justify-end">
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                </div>
                <h3 class="font-display text-lg font-bold text-foreground mb-2">{project.data.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">{project.data.description}</p>
                {project.data.subcategories.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-auto pt-4">
                    {project.data.subcategories.map((tag: string) => (
                      <span class="subcategory-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </Card>
          </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Explore complete works -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div data-reveal>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Explore my complete works
        </h2>
      </div>

      <!-- Segmented filter control -->
      <div class="works-filter-wrap" data-reveal>
        <div class="works-filter" role="group" aria-label="Filter by category">
          {['All', 'LinkedIn', 'Instagram', 'Blogs', 'Print Media', 'Landing Pages'].map((label) => (
            <button
              class={`works-filter-btn${label === 'All' ? ' active' : ''}`}
              data-filter={label === 'All' ? 'all' : label}
            >
              {label}
            </button>
          ))}
        </div>
      </div>

      <!-- Cards grid -->
      <div class="works-grid" id="works-grid">
        {allProjects.map((project) => {
          const slug = project.id.replace(/\.mdx?$/, '');
          const hasBody = project.body && project.body.trim().length > 0;
          return (
          <a
            href={hasBody ? url(`/projects/${slug}`) : project.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="work-card group block"
            data-category={project.data.category}
            data-reveal
          >
            <Card variant="elevated" hover padding="none" class="flex flex-col overflow-hidden h-full">
              {project.data.imageUrl && (
                <div class="case-img-wrap overflow-hidden h-44 shrink-0">
                  <img
                    src={project.data.imageUrl.startsWith('/') ? url(project.data.imageUrl) : project.data.imageUrl}
                    alt={project.data.imageAlt || project.data.title}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex justify-end">
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
                </div>
                <h3 class="font-display text-lg font-bold text-foreground mb-2">{project.data.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed">{project.data.description}</p>
                {project.data.subcategories.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-auto pt-4">
                    {project.data.subcategories.map((tag: string) => (
                      <span class="subcategory-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </Card>
          </a>
          );
        })}
      </div>

      <!-- See more button -->
      <div class="flex justify-center" id="works-see-more-wrap">
        <button id="works-see-more" class="works-see-more-btn">
          See more
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
        </button>
      </div>

      <!-- Empty state -->
      <p class="works-empty hidden text-foreground-muted text-center py-12" id="works-empty">
        No case studies in this category yet — check back soon.
      </p>
    </div>
  </section>

  <!-- Tool Marquee -->
  <ToolMarquee
    badge="My Toolstack"
    title="Tools I work with"
    background="primary"
  />

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Testimonials</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            What clients say
          </h2>
        </div>
      </div>

      {(() => {
        const testimonials = [
          {
            quote: "Over the past few months, Shrishti has supported me with LinkedIn marketing and delivered outstanding results. In a short time, she has shown the initiative and professionalism of someone with much more experience.",
            name: "Steven Raynor",
            role: "Director, Koerting US Corporation",
            initial: "S",
            photo: '/images/testimonials/steven.jfif',
          },
          {
            quote: "Rarely do you find someone who knows what they're doing AND makes the process effortless. Shrishti helped position me in front of the right audience, and the business impact has been undeniable. Highly recommend working with her.",
            name: "Carlo Fortugno",
            role: "CEO, DustAct",
            initial: "C",
            photo: '/images/testimonials/carlo.jpeg',
          },
          {
            quote: "I worked with Shrishti for a few months now and she has exponentially grown my network and increased my profits in my business because of her work. She is very thorough and self-sufficient which is my favorite part about working with her.",
            name: "Lauren Plante",
            role: "Founder and Coach, LPC",
            initial: "L",
            photo: '/images/testimonials/lauren.jfif',
          },
          {
            quote: "Shrishti very quickly helped me cut to the core of what the relevance is of what I do with the correct target market and helped me develop the correct strategy to move forward with in a fun and rewarding way. 100% recommend working with her.",
            name: "Gavin Knox-Grant",
            role: "Founding Director, Karbon Media",
            initial: "G",
            photo: '/images/testimonials/gavin.png',
          },
          {
            quote: "I was starting out as a solopreneur when I decided to hire Shrishti and it was one of the BEST decisions I made! She understood what I needed very quickly and worked to my satisfaction leaving no room for any confusion.",
            name: "Dr. Prachi Khandekar",
            role: "Language Trainer",
            initial: "P",
            photo: '/images/testimonials/prachi.jfif',
          },
        ];
        return (
          <div class="testimonial-carousel" data-reveal>
            <div class="testimonial-slides">
              {testimonials.map((t, i) => (
                <div class={`testimonial-slide${i === 0 ? ' active' : ''}`} aria-hidden={i !== 0 ? 'true' : 'false'}>
                  <div class="flex flex-col gap-4 max-w-2xl mx-auto text-center">
                    <div class="flex gap-1 justify-center text-yellow-400" role="img" aria-label="5 out of 5 stars">
                      {[...Array(5)].map(() => (
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                    <blockquote class="text-lg text-foreground-muted leading-relaxed italic">
                      "{t.quote}"
                    </blockquote>
                    <div class="flex items-center justify-center gap-3 pt-4">
                      <div class="testimonial-avatar" aria-hidden="true">
                        {t.photo ? (
                          <img src={url(t.photo)} alt={t.name} class="w-full h-full object-cover rounded-full" />
                        ) : (
                          <>
                            <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <rect width="64" height="64" rx="32" fill="currentColor" opacity="0.15"/>
                              <circle cx="32" cy="26" r="11" fill="currentColor" opacity="0.4"/>
                              <ellipse cx="32" cy="54" rx="18" ry="12" fill="currentColor" opacity="0.3"/>
                            </svg>
                            <span class="testimonial-avatar-initial">{t.initial}</span>
                          </>
                        )}
                      </div>
                      <div class="text-left">
                        <p class="text-sm font-semibold text-foreground">{t.name}</p>
                        <p class="text-xs text-foreground-muted">{t.role}</p>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="testimonial-dots" aria-hidden="true">
              {testimonials.map((_t, i) => (
                <button class={`testimonial-dot${i === 0 ? ' active' : ''}`} data-slide={i} aria-label={`Go to testimonial ${i + 1}`}></button>
              ))}
            </div>
          </div>
        );
      })()}
    </div>
  </section>

</LandingLayout>

<style>
  /* ---- Hero photo ---- */
  .hero-photo-wrap {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 768px) { .hero-photo-wrap { width: 20rem; height: 20rem; } }
  @media (min-width: 1024px) { .hero-photo-wrap { width: 24rem; height: 24rem; } }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
  }

  /* ---- Brand logo marquee ---- */
  .brand-marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .brand-marquee-inner {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: brand-scroll 30s linear infinite;
  }

  .brand-marquee-track:hover .brand-marquee-inner {
    animation-play-state: paused;
  }

  @keyframes brand-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .brand-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.25s ease;
  }

  .brand-logo-item:hover { opacity: 1; }

  .brand-logo-item img {
    width: 7rem;
    height: 3.5rem;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-marquee-inner { animation: none; }
  }

  /* ---- Testimonial carousel ---- */
  .testimonial-carousel {
    position: relative;
    max-width: 42rem;
    margin: 0 auto;
  }

  .testimonial-slides {
    position: relative;
    min-height: 280px;
  }

  .testimonial-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
  }

  .testimonial-slide.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .testimonial-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .testimonial-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-brand-500, #f7b5dd) 30%, transparent);
    border: none;
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    padding: 0;
  }

  .testimonial-dot.active {
    width: 1.5rem;
    background: var(--color-brand-500, #f7b5dd);
  }

  .testimonial-avatar {
    position: relative;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    color: var(--color-brand-500, #f7b5dd);
  }

  .testimonial-avatar svg { width: 100%; height: 100%; }

  .testimonial-avatar-initial {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brand-500, #f7b5dd);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide { transition: none; }
  }

  /* ---- Works filter ---- */
  .works-filter-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 2px;
  }
  .works-filter-wrap::-webkit-scrollbar { display: none; }

  .works-filter {
    display: inline-flex;
    min-width: max-content;
    background: oklch(14% 0.02 344 / 0.6);
    border: 1px solid oklch(100% 0 0 / 0.08);
    border-radius: 0.625rem;
    padding: 0.25rem;
    gap: 0.125rem;
  }

  .works-filter-btn {
    padding: 0.5rem 1.125rem;
    border-radius: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    background: transparent;
    color: oklch(70% 0.02 344);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
    line-height: 1.4;
  }

  .works-filter-btn:hover:not(.active) {
    background: oklch(100% 0 0 / 0.05);
    color: oklch(90% 0.02 344);
  }

  .works-filter-btn.active {
    background: var(--color-brand-500, #f7b5dd);
    color: oklch(15% 0.03 344);
  }

  /* ---- Works grid ---- */
  .works-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .works-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .works-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .work-card {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .work-card.hidden,
  .work-card.see-more-hidden {
    display: none;
  }

  /* ---- See more button ---- */
  .works-see-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    border: 1px solid oklch(100% 0 0 / 0.12);
    background: oklch(14% 0.02 344 / 0.6);
    color: oklch(80% 0.04 344);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .works-see-more-btn:hover {
    background: var(--color-brand-500, #f7b5dd);
    color: oklch(15% 0.03 344);
    border-color: transparent;
  }

  #works-see-more-wrap.hidden {
    display: none;
  }

  /* ---- Subcategory tags ---- */
  .subcategory-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 0.25rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: 1px solid oklch(100% 0 0 / 0.1);
    color: oklch(65% 0.04 344);
    background: oklch(100% 0 0 / 0.03);
  }

  /* ---- Empty state ---- */
  .works-empty {
    font-size: 0.95rem;
  }

  /* ---- Case study image: greyscale → plum on hover ---- */
  .case-img-wrap {
    position: relative;
  }

  /* Greyscale by default */
  .case-img-wrap img {
    filter: grayscale(100%);
    transition: filter 0.45s ease, transform 0.3s ease;
  }

  /* Plum colour overlay — invisible until hover */
  .case-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    /* Plum from the #37090C family — lifted in lightness so mix-blend-mode: color has effect */
    background: oklch(38% 0.22 15);
    mix-blend-mode: color;
    opacity: 0;
    transition: opacity 0.45s ease;
    pointer-events: none;
  }

  /* On group hover: lift greyscale, fade in plum tint */
  .group:hover .case-img-wrap img {
    filter: grayscale(0%);
  }

  .group:hover .case-img-wrap::after {
    opacity: 0.75;
  }

  @media (prefers-reduced-motion: reduce) {
    .case-img-wrap img { transition: none; }
    .case-img-wrap::after { transition: none; }
  }
</style>

<script>
  function initTestimonialCarousel() {
    const carousel = document.querySelector('.testimonial-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll<HTMLElement>('.testimonial-slide');
    const dots = carousel.querySelectorAll<HTMLElement>('.testimonial-dot');
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current].classList.add('active');
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); startAuto(); });
    });

    startAuto();
  }

  initTestimonialCarousel();

  function initWorksFilter() {
    const btns = document.querySelectorAll<HTMLButtonElement>('.works-filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.work-card');
    const empty = document.getElementById('works-empty');
    const seeMoreWrap = document.getElementById('works-see-more-wrap');
    const seeMoreBtn = document.getElementById('works-see-more');
    const PAGE_SIZE = 4;

    function applyFilter(filter: string) {
      const matching: HTMLElement[] = [];
      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('hidden', !show);
        card.classList.remove('see-more-hidden');
        if (show) matching.push(card);
      });

      // Collapse cards beyond the first row
      matching.slice(PAGE_SIZE).forEach((card) => card.classList.add('see-more-hidden'));

      if (empty) empty.classList.toggle('hidden', matching.length > 0);
      if (seeMoreWrap) seeMoreWrap.classList.toggle('hidden', matching.length <= PAGE_SIZE);
    }

    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        applyFilter(btn.dataset.filter ?? 'all');
      });
    });

    if (seeMoreBtn && seeMoreWrap) {
      seeMoreBtn.addEventListener('click', () => {
        cards.forEach((card) => card.classList.remove('see-more-hidden'));
        seeMoreWrap.classList.add('hidden');
      });
    }

    applyFilter('all');
  }

  initWorksFilter();
</script>
