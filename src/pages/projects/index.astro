---
/**
 * Projects page
 * URL: /projects
 */
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import ToolMarquee from '@/components/landing/ToolMarquee.astro';
import { getCollection } from 'astro:content';
import { url } from '@/lib/url';

// Merge featured (ordered) + rest (alphabetical), deduplicate by id
const featuredItems = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const allItems = await getCollection('projects', ({ data }) => !data.draft);
const featuredIds = new Set(featuredItems.map((p) => p.id));
const restItems = allItems
  .filter((p) => !featuredIds.has(p.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allProjects = [...featuredItems, ...restItems];
const INITIAL_VISIBLE = 9;
---

<LandingLayout
  title="Projects — The S Curve"
  description="Selected work — marketing strategy, content, and growth engagements."
  showContactFooter={true}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       Hero + brands share ONE video background that fades at the marquee end
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="hero-video-zone">
    <!-- Shared video layer (dark mode only) -->
    <div class="hvz-video-wrap" aria-hidden="true">
      <video
        class="hvz-video"
        src={url("/videos/hero-bg.mp4")}
        autoplay
        loop
        muted
        playsinline
        preload="auto"
        data-speed="0.825"
      />
      <div class="hvz-overlay"></div>
    </div>

    <!-- Hero — no videoBg prop; video-has-bg keeps it transparent in dark mode -->
    <Hero layout="split" size="xl" class="hero-dark-gradient video-has-bg" showScrollIndicator>
      <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-300">Available for consulting &amp; projects</Badge>

      <h1 slot="title">
        <span class="text-foreground [-webkit-text-fill-color:currentColor]">I'm Shrishti,</span><br />
        <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] !text-2xl md:!text-3xl lg:!text-3xl !font-semibold !leading-snug">Marketer + Business Strategist</span>
      </h1>

      <p slot="description">
        I solve messy marketing problems across systems, positioning, and growth.
      </p>

      <Fragment slot="actions">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={url("/contact")}>
          <Icon name="mail" size="sm" />
          Contact me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </Fragment>

      <div slot="aside" class="flex items-center justify-center lg:justify-end">
        <div class="hero-photo-wrap">
          <div class="absolute inset-0 rounded-2xl bg-brand-500/15 blur-3xl scale-90" aria-hidden="true"></div>
          <img
            src={url("/images/photo.png")}
            alt="Shrishti S Nagar"
            width="400"
            height="400"
            class="hero-photo"
          />
        </div>
      </div>
    </Hero>

    <!-- Brands — transparent in dark mode so the shared video shows through -->
    <section class="relative z-10 py-12 bg-background dark:bg-transparent">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <div class="flex items-center gap-4" data-reveal>
        <div class="h-px flex-1 bg-border/50"></div>
        <p class="text-xs font-medium uppercase tracking-widest text-foreground-muted">Across industries and markets</p>
        <div class="h-px flex-1 bg-border/50"></div>
      </div>

      <div class="brand-marquee-track">
        <div class="brand-marquee-inner">
          {[
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
          ].map(({ src, alt }) => (
            <div class="brand-logo-item">
              <img src={src} alt={alt} height="40" loading="lazy" draggable="false" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  </div>{/* end .hero-video-zone */}

  <!-- All Case Studies — editorial 3-column layout -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="px-6">

      {(() => {
        const leftCards   = allProjects.filter((_, i) => i % 3 === 0);
        const centerCards = allProjects.filter((_, i) => i % 3 === 1);
        const rightCards  = allProjects.filter((_, i) => i % 3 === 2);
        // INITIAL_VISIBLE = 9 → 3 per column
        const colVisible  = Math.ceil(INITIAL_VISIBLE / 3);

        const renderCard = (project: typeof allProjects[number], hidden: boolean) => {
          const slug   = project.id.replace(/\.mdx?$/, '');
          const hasBody = project.body && project.body.trim().length > 0;
          return (
            <a
              href={hasBody ? url(`/projects/${slug}`) : project.data.url}
              target={hasBody ? undefined : '_blank'}
              rel={hasBody ? undefined : 'noopener noreferrer'}
              class={`cs-card group block${hidden ? ' editorial-hidden' : ''}`}
            >
              <div class="cs-card-inner">
                <div class="case-img-wrap cs-img">
                  <img
                    src={project.data.imageUrl ? (project.data.imageUrl.startsWith('/') ? url(project.data.imageUrl) : project.data.imageUrl) : ''}
                    alt={project.data.imageAlt || project.data.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="cs-overlay">
                  <p class="cs-description">{project.data.description}</p>
                  {project.data.subcategories && project.data.subcategories.length > 0 && (
                    <div class="cs-tags">
                      {project.data.subcategories.map((tag: string) => (
                        <span class="subcategory-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                  <div class="cs-title-row">
                    <h3 class="cs-title">{project.data.title}</h3>
                    <Icon name="arrow-up-right" size="sm" class="cs-arrow" />
                  </div>
                </div>
              </div>
            </a>
          );
        };

        return (
          <div class="editorial-columns" id="editorial-grid">
            <div class="editorial-col editorial-col-side">
              {leftCards.map((p, j) => renderCard(p, j >= colVisible))}
            </div>
            <div class="editorial-col editorial-col-center">
              {centerCards.map((p, j) => renderCard(p, j >= colVisible))}
            </div>
            <div class="editorial-col editorial-col-side">
              {rightCards.map((p, j) => renderCard(p, j >= colVisible))}
            </div>
          </div>
        );
      })()}

    </div>

    {allProjects.length > INITIAL_VISIBLE && (
      <div class="flex justify-center mt-8 px-6" id="editorial-see-more-wrap">
        <button id="editorial-see-more-btn" class="works-see-more-btn" type="button">
          See more
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </button>
      </div>
    )}
  </section>

  <script is:inline>
    (function () {
      const btn = document.getElementById('editorial-see-more-btn');
      const wrap = document.getElementById('editorial-see-more-wrap');
      if (!btn) return;
      btn.addEventListener('click', function () {
        const hidden = document.querySelectorAll('.editorial-hidden');
        hidden.forEach(function (el) { el.classList.remove('editorial-hidden'); });
        if (wrap) wrap.style.display = 'none';
      });
    })();
  </script>

  <!-- Tool Marquee -->
  <ToolMarquee
    badge="My Toolstack"
    title="Tools I work with"
    background="primary"
  />

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Testimonials</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            What clients say
          </h2>
        </div>
      </div>

      {(() => {
        const testimonials = [
          {
            quote: "Over the past few months, Shrishti has supported me with LinkedIn marketing and delivered outstanding results. In a short time, she has shown the initiative and professionalism of someone with much more experience.",
            name: "Steven Raynor",
            role: "Director, Koerting US Corporation",
            initial: "S",
            photo: '/images/testimonials/steven.jfif',
          },
          {
            quote: "Rarely do you find someone who knows what they're doing AND makes the process effortless. Shrishti helped position me in front of the right audience, and the business impact has been undeniable. Highly recommend working with her.",
            name: "Carlo Fortugno",
            role: "CEO, DustAct",
            initial: "C",
            photo: '/images/testimonials/carlo.jpeg',
          },
          {
            quote: "I worked with Shrishti for a few months now and she has exponentially grown my network and increased my profits in my business because of her work. She is very thorough and self-sufficient which is my favorite part about working with her.",
            name: "Lauren Plante",
            role: "Founder and Coach, LPC",
            initial: "L",
            photo: '/images/testimonials/lauren.jfif',
          },
          {
            quote: "Shrishti very quickly helped me cut to the core of what the relevance is of what I do with the correct target market and helped me develop the correct strategy to move forward with in a fun and rewarding way. 100% recommend working with her.",
            name: "Gavin Knox-Grant",
            role: "Founding Director, Karbon Media",
            initial: "G",
            photo: '/images/testimonials/gavin.png',
          },
          {
            quote: "I was starting out as a solopreneur when I decided to hire Shrishti and it was one of the BEST decisions I made! She understood what I needed very quickly and worked to my satisfaction leaving no room for any confusion.",
            name: "Dr. Prachi Khandekar",
            role: "Language Trainer",
            initial: "P",
            photo: '/images/testimonials/prachi.jfif',
          },
        ];
        const items = [...testimonials, ...testimonials]; /* duplicate for seamless loop */
        return (
          <div class="testimonial-marquee-track" data-reveal>
            <div class="testimonial-marquee-inner">
              {items.map((t) => (
                <div class="testimonial-card">
                  <div class="flex gap-1 mb-4 text-yellow-400">
                    {[...Array(5)].map(() => (
                      <svg class="w-4 h-4 fill-current shrink-0" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                  <blockquote class="text-sm text-foreground-muted leading-relaxed italic flex-1">
                    "{t.quote}"
                  </blockquote>
                  <div class="flex items-center gap-3 mt-5">
                    <div class="testimonial-avatar shrink-0">
                      {t.photo ? (
                        <img src={url(t.photo)} alt={t.name} class="w-full h-full object-cover rounded-full" />
                      ) : (
                        <span class="testimonial-avatar-initial">{t.initial}</span>
                      )}
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-foreground">{t.name}</p>
                      <p class="text-xs text-foreground-muted">{t.role}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })()}
    </div>
  </section>

</LandingLayout>

<style>
  /* ════════════════════════════════════════════════════════════════════════
     Hero-video zone: hero + brands share a single video background
     ════════════════════════════════════════════════════════════════════════ */

  /* Stacking context for the shared video */
  .hero-video-zone {
    position: relative;
    overflow: hidden;
  }

  /* Video wrapper — hidden in light mode, shown in dark */
  .hvz-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    display: none;
  }
  :global(.dark) .hvz-video-wrap {
    display: block;
  }

  /* Video element — same filter as the Hero's own video */
  .hvz-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 1s ease;
    filter: saturate(70%) hue-rotate(130deg) brightness(0.55) contrast(1.10);
  }
  .hvz-video.is-loaded { opacity: 1; }

  /* Overlay:
     - wine radial tint (same as Hero's overlay)
     - gradient fades to background at the very bottom of the brands section
       (≈ 85 % into the wrapper height) for a seamless dissolve             */
  .hvz-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, transparent 65%, var(--color-background) 100%),
      radial-gradient(ellipse at 30% 40%, oklch(28% 0.10 344 / 0.60) 0%, oklch(8% 0.04 344 / 0.80) 100%);
    mix-blend-mode: multiply;
  }

  /* ---- Hero photo ---- */
  .hero-photo-wrap {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 768px) { .hero-photo-wrap { width: 20rem; height: 20rem; } }
  @media (min-width: 1024px) { .hero-photo-wrap { width: 24rem; height: 24rem; } }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
  }

  /* ---- Brand logo marquee ---- */
  .brand-marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .brand-marquee-inner {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: brand-scroll 30s linear infinite;
  }

  .brand-marquee-track:hover .brand-marquee-inner {
    animation-play-state: paused;
  }

  @keyframes brand-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .brand-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.25s ease;
  }

  .brand-logo-item:hover { opacity: 1; }

  .brand-logo-item img {
    width: 7rem;
    height: 3.5rem;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-marquee-inner { animation: none; }
  }

  /* ---- Testimonial marquee ---- */
  .testimonial-marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .testimonial-marquee-inner {
    display: flex;
    gap: 1.5rem;
    width: max-content;
    animation: testimonial-scroll 60s linear infinite;
  }

  .testimonial-marquee-track:hover .testimonial-marquee-inner {
    animation-play-state: paused;
  }

  @keyframes testimonial-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .testimonial-card {
    width: 22rem;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    background: var(--color-background-secondary, oklch(14% 0.02 344 / 0.5));
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .testimonial-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-brand-500) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonial-avatar-initial {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brand-500);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-marquee-inner { animation: none; }
  }

  /* ---- Editorial 3-column layout ---- */
  .editorial-columns {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .editorial-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .editorial-col-side   { flex: 1; }
  .editorial-col-center { flex: 1.15; }

  /* Mobile: stack all as single column */
  @media (max-width: 1023px) {
    .editorial-columns {
      flex-direction: column;
    }
    .editorial-col {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .editorial-col > * {
      flex: 1 1 calc(50% - 0.375rem);
    }
  }

  .editorial-hidden {
    display: none;
  }

  /* ---- See more button ---- */
  .works-see-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.625rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    border: 1px solid oklch(100% 0 0 / 0.12);
    background: oklch(14% 0.02 344 / 0.6);
    color: oklch(80% 0.04 344);
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease;
  }

  .works-see-more-btn:hover {
    background: var(--color-brand-500, #f7b5dd);
    color: oklch(15% 0.03 344);
    border-color: transparent;
  }

  /* ---- Subcategory tags ---- */
  .subcategory-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 0.25rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: 1px solid oklch(100% 0 0 / 0.1);
    color: oklch(65% 0.04 344);
    background: oklch(100% 0 0 / 0.03);
  }

  /* ---- Empty state ---- */
  .works-empty {
    font-size: 0.95rem;
  }

  /* ---- Case study card: full-bleed image + overlay ---- */
  .cs-card-inner {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: 1 / 1;
    width: 100%;
    box-shadow: 0 4px 24px -4px rgba(0,0,0,0.18);
  }

  .cs-img {
    position: absolute;
    inset: 0;
  }

  /* Greyscale by default, full colour on hover with brightness boost */
  .case-img-wrap img {
    filter: grayscale(100%) brightness(0.85);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .cs-card:hover .case-img-wrap img {
    filter: grayscale(0%) brightness(1.05) saturate(1.2);
  }

  /* Gradient overlay */
  .cs-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.25rem;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.80) 0%,
      rgba(0,0,0,0.35) 40%,
      transparent 70%
    );
    transition: background 0.4s ease;
  }

  .cs-card:hover .cs-overlay {
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.65) 0%,
      rgba(0,0,0,0.15) 45%,
      transparent 70%
    );
  }

  /* Description — hidden, slides up on hover */
  .cs-description {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.80);
    line-height: 1.55;
    margin-bottom: 0.6rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .cs-card:hover .cs-description {
    opacity: 0;
    transform: translateY(8px);
  }

  /* Tags — hidden, appear with description */
  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.6rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.35s ease 0.04s, transform 0.35s ease 0.04s;
  }

  .cs-card:hover .cs-tags {
    opacity: 1;
    transform: translateY(0);
  }

  /* Title row — always visible */
  .cs-title-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .cs-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .cs-arrow {
    color: rgba(255,255,255,0.7);
    flex-shrink: 0;
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .cs-card:hover .cs-arrow {
    color: #fff;
    transform: translate(2px, -2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-description, .cs-tags, .case-img-wrap img { transition: none; }
  }
</style>

<script is:inline>
  /* Fade in the shared hero-video-zone video once it can play */
  (function () {
    function initHvzVideo() {
      document.querySelectorAll('video.hvz-video').forEach(function (v) {
        const speed = parseFloat(v.getAttribute('data-speed') || '0.75');
        if (!isNaN(speed) && speed > 0) v.playbackRate = speed;
        if (v.readyState >= 3) {
          v.classList.add('is-loaded');
        } else {
          v.addEventListener('canplay', function () { v.classList.add('is-loaded'); }, { once: true });
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHvzVideo);
    } else {
      initHvzVideo();
    }
  })();
</script>

