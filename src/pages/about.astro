---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import ToolMarquee from '@/components/landing/ToolMarquee.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="About Shrishti S Nagar — Marketing Strategist"
  description="8 years of marketing experience. I combine empathy, systems thinking, and real market data to help B2B leaders become the obvious choice."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About me
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Marketing, Systems</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">and Psychology.</span>
    </h1>
    <p slot="description">
      8 years of experience building marketing that doesn't just look good — it changes how people feel about a brand. Here's how I think and work.
    </p>
  </Hero>

  <!-- My story -->
  <section class="py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col gap-4" data-reveal="right">
          <div class="flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">The approach</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Empathy is a<br /> business strategy.
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed">
            8 years of marketing experience has taught me one thing — people don't remember you or your product but they do remember how you made them feel. And it's that feeling that I deliver to audiences. I'm an empath, a feeler, blessed with a logical mind — and that's a dangerous combination for reverse engineering and delivering what people want.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            I work with B2B leaders who are done with generic playbooks and AI-generated noise. My work sits at the intersection of strategy, narrative, and systems — so the marketing you build with me actually compounds over time.
          </p>
        </div>
        <div class="flex flex-col gap-4 h-full" data-reveal="left" data-reveal-delay="1">
          <Card variant="elevated" hover class="flex-1 flex flex-col justify-center">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="target" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">Specialisation</p>
                <h3 class="text-base font-semibold text-foreground">B2B Marketing Strategy</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Positioning, content, lead generation, and growth systems. Built around how your business actually works — not a template.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Strategy</Badge>
                  <Badge size="sm" variant="brand">Positioning</Badge>
                  <Badge size="sm" variant="brand">Growth</Badge>
                </div>
              </div>
            </div>
          </Card>
          <Card variant="elevated" hover class="flex-1 flex flex-col justify-center">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="globe" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide text-foreground-muted mb-1">Based in India · Working worldwide</p>
                <h3 class="text-base font-semibold text-foreground">8 years · 100+ projects</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Clients across the US, Europe, and Asia-Pacific. Time zones are never a problem when the communication is clear.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">New Delhi</Badge>
                  <Badge size="sm" variant="brand">Remote-first</Badge>
                </div>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- How I work -->
  <section class="py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>My Process</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            How I Work
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          These aren't aspirations — they're the constraints every engagement is held to, from the first conversation to the final handover.
        </p>
      </div>
      <!-- Numbered step layout — no cards, dividers create structure -->
      <div class="grid md:grid-cols-3 gap-px bg-border rounded-2xl overflow-hidden ring-1 ring-border">
        <div class="bg-background px-8 py-10" data-reveal>
          <span class="block font-mono text-6xl font-black text-brand-500/20 leading-none mb-6 tabular-nums select-none" aria-hidden="true">01</span>
          <h3 class="text-base font-semibold text-foreground mb-3">Start with the real problem</h3>
          <p class="text-sm text-foreground-muted leading-relaxed">
            Most marketing problems are positioning problems in disguise. I diagnose before I prescribe — so the strategy actually fits.
          </p>
        </div>
        <div class="bg-background px-8 py-10" data-reveal data-reveal-delay="1">
          <span class="block font-mono text-6xl font-black text-brand-500/20 leading-none mb-6 tabular-nums select-none" aria-hidden="true">02</span>
          <h3 class="text-base font-semibold text-foreground mb-3">Build for humans</h3>
          <p class="text-sm text-foreground-muted leading-relaxed">
            Every piece of messaging is written for a real person, not a persona. No AI slop, no generic frameworks — just clear, resonant communication.
          </p>
        </div>
        <div class="bg-background px-8 py-10" data-reveal data-reveal-delay="2">
          <span class="block font-mono text-6xl font-black text-brand-500/20 leading-none mb-6 tabular-nums select-none" aria-hidden="true">03</span>
          <h3 class="text-base font-semibold text-foreground mb-3">Systems over heroics</h3>
          <p class="text-sm text-foreground-muted leading-relaxed">
            Good marketing shouldn't require you to be everywhere all the time. I design repeatable systems so growth compounds without burning you out.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tool Stack -->
  <ToolMarquee
    badge="My Toolstack"
    title="Tools I work with"
    background="primary"
  />

  <!-- FAQ -->
  <section class="py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Good to know</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Frequently asked questions
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Some of the questions I get asked most often.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Card 1: About marketing -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="target" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">About marketing</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-marketing">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What kind of marketing do you do?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                I work across strategy, positioning, content, and growth systems — primarily for B2B companies. This means figuring out what you should be saying, who you should be saying it to, and building the infrastructure to do it consistently.
              </div>
            </details>
            <details class="border-b border-border" name="faq-marketing">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you work with B2C brands?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Occasionally — but my sweet spot is B2B. The longer sales cycles, relationship-driven dynamics, and complex buying committees are where my approach to narrative and positioning creates the most leverage.
              </div>
            </details>
            <details class="border-b border-border" name="faq-marketing">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How is this different from hiring an agency?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                You work directly with me — not an account manager who relays everything to a junior team. I bring 8 years of experience to every engagement, and I'm genuinely invested in outcomes, not just deliverables.
              </div>
            </details>
            <details class="border-b border-border" name="faq-marketing">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you use AI in your work?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes — as a research and thinking tool, not a content factory. Everything client-facing is written and reviewed by me. The positioning, the voice, the strategy — that's all human work.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-marketing">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What results can I expect?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                It depends on where you are and what we build together. Most clients come away with sharper positioning, clearer messaging, and systems that generate inbound interest without constant effort. I'll be honest in our first call about what's realistic for your situation.
              </div>
            </details>
          </div>
        </Card>

        <!-- Card 2: About working together -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="users" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">Working together</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What does a typical engagement look like?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Usually it starts with a clarity call to understand your business, goals, and gaps. From there we define the scope — whether that's a one-time strategy sprint, a positioning overhaul, or an ongoing retainer.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How long does a project take?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Strategy sprints typically run 2–4 weeks. Larger engagements (positioning + content system + execution) are usually 2–3 months. I'll give you a realistic timeline before we start.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you take on ongoing retainers?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. For clients who want consistent strategic support, content creation, or help running their growth systems, I offer monthly retainers. Scope and hours are agreed upfront.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you work with international clients?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Absolutely. I'm based in New Delhi but work with clients across the US, Europe, and Asia-Pacific. Most engagements are fully remote and async-friendly.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How do I get started?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Book a 1:1 clarity call via Calendly — it's free, no commitment. We'll talk through your situation and I'll tell you honestly if and how I can help.
              </div>
            </details>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a good fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        If my background and approach match what you're looking for, I'm open to new projects. Let's have a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a good fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        If my background and approach match what you're looking for, I'm open to new projects. Let's have a conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>

<style>
  details[open] > summary .faq-icon {
    transform: rotate(180deg);
  }

  /* Keyboard focus ring on FAQ summaries */
  summary:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>
