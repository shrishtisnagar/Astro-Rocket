---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import ToolMarquee from '@/components/landing/ToolMarquee.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';
import { url } from '@/lib/url';
import { fetchRSSPosts } from '@/lib/rss';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const allRSSPosts = await fetchRSSPosts();
const posts = allRSSPosts.slice(0, 3);
---

<LandingLayout
  title="Shrishti S Nagar — Marketing Strategist"
  description="I solve messy marketing problems across systems, positioning, and growth."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="split" size="xl" class="hero-dark-gradient" showScrollIndicator showAurora videoBg={url("/videos/hero-bg.mp4")}>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Available for consulting &amp; projects</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">I'm Shrishti,</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">Marketer + Business Strategist</span>
    </h1>

    <p slot="description">
      I solve messy marketing problems across systems, positioning, and growth.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer">
        Book a call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href={url("/projects")}>
        <Icon name="layers" size="sm" />
        View my work
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div slot="aside" class="flex items-center justify-center lg:justify-end">
      <div class="hero-photo-wrap">
        <div class="absolute inset-0 rounded-2xl bg-brand-500/15 blur-3xl scale-90" aria-hidden="true"></div>
        <img
          src={url("/images/photo.png")}
          alt="Shrishti S Nagar"
          width="400"
          height="400"
          class="hero-photo"
        />
      </div>
    </div>
  </Hero>

  <!-- Services Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Engineering narrative that makes you the obvious choice
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          I work with leaders and teams who are sick and tired of AI slop and want to solve their business problems by going deeper.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Marketing Strategy -->
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="target" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Marketing Strategy</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Clarity on what to say, who to target, and how to grow. All of this based on real market data and projections.
              </p>
            </div>
          </div>
        </Card>

        <!-- Content & Positioning -->
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="edit" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Content &amp; Positioning</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Turning data into non-AI, HUMAN messaging that builds trust. Positioning that makes you the obvious choice rather than one of many.
              </p>
            </div>
          </div>
        </Card>

        <!-- Growth Systems -->
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="trending-up" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Growth Systems</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Designing repeatable systems for lead generation, content, and outreach. Built to run without you having to reinvent things every month.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="work" class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Selected work</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Projects I'm proud of
          </h2>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {featuredProjects.map((project) => (
          <Card variant="elevated" hover padding="lg" href={url(`/projects/${project.id.replace(/\.mdx?$/, '')}`)} class="group flex flex-col" data-reveal>
            <div class="flex flex-1 flex-col">
              <div class="mb-3 flex items-start justify-between gap-4">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layers" size="sm" />
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
              </div>
              <div class="mb-2 flex items-baseline gap-2">
                <h3 class="font-display text-lg font-bold text-foreground">{project.data.title}</h3>
                {project.data.year && (
                  <span class="text-xs text-foreground-muted">{project.data.year}</span>
                )}
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed mb-4 flex-1">{project.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <Badge variant="brand">{tag}</Badge>
                ))}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Testimonials</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            What clients say
          </h2>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Testimonial 1 -->
        <Card variant="elevated" padding="lg" hover data-reveal>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 out of 5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Over the past few months, Shrishti has supported me with LinkedIn marketing and delivered outstanding results. In a short time, she has shown the initiative and professionalism of someone with much more experience."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                S
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Steven Raynor</p>
                <p class="text-xs text-foreground-muted">Director, Koerting US Corporation</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2 -->
        <Card variant="elevated" padding="lg" hover data-reveal data-reveal-delay="1">
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 out of 5 stars">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Rarely do you find someone who knows what they're doing AND makes the process effortless. Shrishti helped position me in front of the right audience, and the business impact has been undeniable. Highly recommend working with her."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                C
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Carlo Fortugno</p>
                <p class="text-xs text-foreground-muted">CEO, DustAct</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Tool Marquee -->
  <ToolMarquee
    badge="My Toolstack"
    title="Tools I work with"
    background="primary"
  />

  <!-- About Teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center" data-reveal="right">
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start">About Shrishti</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Marketing, Systems<br />
              <span class="text-brand-500">and Psychology.</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            8 years of marketing experience has taught me one thing — people don't remember you or your product but they do remember how you made them feel. And it's that feeling that I deliver to audiences. I'm an empath, a feeler, blessed with a logical mind — and that's a dangerous combination for reverse engineering and delivering what people want.
          </p>
          <Button variant="outline" href={url("/about")} class="self-start">
            More about me
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1">
          <p class="text-sm text-foreground mb-5 text-center">A few things about me.</p>
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="history" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">8 Years Experience</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="briefcase" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">100+ Projects</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="globe" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Working worldwide</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="map-pin" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Based in India</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start">From the newsletter</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Latest reads
          </h2>
        </div>
        <a href={url("/blog")} class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.title}
            description={post.description}
            href={post.href}
            publishedAt={post.publishedAt}
            tags={post.tags}
            author={post.author}
            imageUrl={post.imageUrl}
          />
        ))}
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href={url("/blog")}>
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Have a project in mind?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Let's talk. Book a direct call with me or connect via other channels.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={url("/contact")}>
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Have a project in mind?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Let's talk. Book a direct call with me or connect via other channels.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={url("/contact")}>
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>

<style>
  .hero-photo-wrap {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 768px) {
    .hero-photo-wrap {
      width: 20rem;
      height: 20rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-photo-wrap {
      width: 24rem;
      height: 24rem;
    }
  }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    /* Fade all edges into the background — no hard border */
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
  }
</style>

<script>
  function initCountup() {
    const counters = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-countup-init])');
    if (counters.length === 0) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countup ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((el) => {
      el.dataset.countupInit = 'true';
      observer.observe(el);
    });
  }

  initCountup();
</script>

</LandingLayout>
