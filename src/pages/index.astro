---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { url } from '@/lib/url';
---

<LandingLayout
  title="Shrishti S Nagar — Marketing Strategist"
  description="I solve messy marketing problems across systems, positioning, and growth."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="split" size="xl" class="hero-dark-gradient" showScrollIndicator videoSpeed={0.825} videoBg={url("/videos/hero-bg.mp4")}>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-300">Available for consulting &amp; projects</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">I'm Shrishti,</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] !text-2xl md:!text-3xl lg:!text-3xl !font-semibold !leading-snug">Marketer + Business Strategist</span>
    </h1>

    <p slot="description">
      I solve messy marketing problems across systems, positioning, and growth.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer">
        Book a call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href={url("/projects")}>
        <Icon name="layers" size="sm" />
        View my work
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div slot="aside" class="flex items-center justify-center lg:justify-end">
      <div class="hero-photo-wrap">
        <div class="absolute inset-0 rounded-2xl bg-[#210300]/50 blur-3xl scale-90" aria-hidden="true"></div>
        <img
          src={url("/images/photo.png")}
          alt="Shrishti S Nagar"
          width="400"
          height="400"
          class="hero-photo"
        />
      </div>
    </div>
  </Hero>

</LandingLayout>

<style>
  .hero-photo-wrap {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 768px) {
    .hero-photo-wrap {
      width: 20rem;
      height: 20rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-photo-wrap {
      width: 24rem;
      height: 24rem;
    }
  }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
  }
</style>
