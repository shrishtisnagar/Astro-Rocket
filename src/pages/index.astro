---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import ToolMarquee from '@/components/landing/ToolMarquee.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';
import { url } from '@/lib/url';
import { fetchRSSPosts } from '@/lib/rss';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const allRSSPosts = await fetchRSSPosts();
const posts = allRSSPosts.slice(0, 3);
---

<LandingLayout
  title="Shrishti S Nagar — Marketing Strategist"
  description="I solve messy marketing problems across systems, positioning, and growth."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="split" size="xl" class="hero-dark-gradient" showScrollIndicator showAurora videoBg={url("/videos/hero-bg.mp4")}>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-300">Available for consulting &amp; projects</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">I'm Shrishti,</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] !text-2xl md:!text-3xl lg:!text-3xl !font-semibold !leading-snug">Marketer + Business Strategist</span>
    </h1>

    <p slot="description">
      I solve messy marketing problems across systems, positioning, and growth.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer">
        Book a call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href={url("/projects")}>
        <Icon name="layers" size="sm" />
        View my work
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>

    <div slot="aside" class="flex items-center justify-center lg:justify-end">
      <div class="hero-photo-wrap">
        <div class="absolute inset-0 rounded-2xl bg-brand-500/15 blur-3xl scale-90" aria-hidden="true"></div>
        <img
          src={url("/images/photo.png")}
          alt="Shrishti S Nagar"
          width="400"
          height="400"
          class="hero-photo"
        />
      </div>
    </div>
  </Hero>

  <!-- Brands Section -->
  <section class="relative z-10 py-12 bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-12">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Clients</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Brands I've worked with
          </h2>
        </div>
      </div>

      <!-- Logo marquee — add more <img> entries as you upload logos to public/images/brands/ -->
      <div class="brand-marquee-track">
        <div class="brand-marquee-inner">
          {[
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
            /* duplicate set for seamless loop */
            { src: url('/images/brands/aveneera.svg'),  alt: 'Aveneera' },
            { src: url('/images/brands/coachos.svg'),   alt: 'Coachos' },
            { src: url('/images/brands/dustact.svg'),   alt: 'DustAct' },
            { src: url('/images/brands/koerting.svg'),  alt: 'Koerting' },
            { src: url('/images/brands/lpc.svg'),       alt: 'LPC' },
            { src: url('/images/brands/microapp.svg'),  alt: 'Microapp' },
            { src: url('/images/brands/owled.svg'),     alt: 'Owled' },
            { src: url('/images/brands/pepper.svg'),    alt: 'Pepper' },
          ].map(({ src, alt }) => (
            <div class="brand-logo-item">
              <img src={src} alt={alt} height="40" loading="lazy" draggable="false" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="work" class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Selected work</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Projects I'm proud of
          </h2>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {featuredProjects.map((project, i) => (
          <Card variant="elevated" hover padding="none" href={url(`/projects/${project.id.replace(/\.mdx?$/, '')}`)} class="group flex flex-col overflow-hidden" data-reveal>
            <!-- Placeholder image thumbnail -->
            <div class="project-thumb" style={`--thumb-hue: ${(i * 67 + 20) % 360}`} aria-hidden="true">
              <div class="project-thumb-icon">
                <Icon name="layers" size="md" />
              </div>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="mb-3 flex items-start justify-between gap-4">
                <div class="mb-2 flex items-baseline gap-2 flex-1 min-w-0">
                  <h3 class="font-display text-lg font-bold text-foreground">{project.data.title}</h3>
                  {project.data.year && (
                    <span class="text-xs text-foreground-muted shrink-0">{project.data.year}</span>
                  )}
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0 mt-1" />
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed mb-4 flex-1">{project.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <Badge variant="brand">{tag}</Badge>
                ))}
              </div>
            </div>
          </Card>
        ))}
      </div>

      <div class="flex justify-center" data-reveal>
        <Button variant="outline" href={url("/projects")}>
          See more projects
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Testimonials</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            What clients say
          </h2>
        </div>
      </div>

      <!-- Testimonial Carousel -->
      {(() => {
        const testimonials = [
          {
            quote: "Over the past few months, Shrishti has supported me with LinkedIn marketing and delivered outstanding results. In a short time, she has shown the initiative and professionalism of someone with much more experience.",
            name: "Steven Raynor",
            role: "Director, Koerting US Corporation",
            initial: "S",
            photo: '/images/testimonials/steven.jfif',
          },
          {
            quote: "Rarely do you find someone who knows what they're doing AND makes the process effortless. Shrishti helped position me in front of the right audience, and the business impact has been undeniable. Highly recommend working with her.",
            name: "Carlo Fortugno",
            role: "CEO, DustAct",
            initial: "C",
            photo: '/images/testimonials/carlo.jpeg',
          },
          {
            quote: "I worked with Shrishti for a few months now and she has exponentially grown my network and increased my profits in my business because of her work. She is very thorough and self-sufficient which is my favorite part about working with her.",
            name: "Lauren Plante",
            role: "Founder and Coach, LPC",
            initial: "L",
            photo: '/images/testimonials/lauren.jfif',
          },
          {
            quote: "Shrishti very quickly helped me cut to the core of what the relevance is of what I do with the correct target market and helped me develop the correct strategy to move forward with in a fun and rewarding way. 100% recommend working with her.",
            name: "Gavin Knox-Grant",
            role: "Founding Director, Karbon Media",
            initial: "G",
            photo: '/images/testimonials/gavin.png',
          },
          {
            quote: "I was starting out as a solopreneur when I decided to hire Shrishti and it was one of the BEST decisions I made! She understood what I needed very quickly and worked to my satisfaction leaving no room for any confusion.",
            name: "Dr. Prachi Khandekar",
            role: "Language Trainer",
            initial: "P",
            photo: '/images/testimonials/prachi.jfif',
          },
        ];
        return (
          <div class="testimonial-carousel" data-reveal>
            <div class="testimonial-slides">
              {testimonials.map((t, i) => (
                <div class={`testimonial-slide${i === 0 ? ' active' : ''}`} aria-hidden={i !== 0 ? 'true' : 'false'}>
                  <div class="flex flex-col gap-4 max-w-2xl mx-auto text-center">
                    <div class="flex gap-1 justify-center text-yellow-400" role="img" aria-label="5 out of 5 stars">
                      {[...Array(5)].map(() => (
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                    <blockquote class="text-lg text-foreground-muted leading-relaxed italic">
                      "{t.quote}"
                    </blockquote>
                    <div class="flex items-center justify-center gap-3 pt-4">
                      <div class="testimonial-avatar" aria-hidden="true">
                        {t.photo ? (
                          <img src={url(t.photo)} alt={t.name} class="w-full h-full object-cover rounded-full" />
                        ) : (
                          <>
                            <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                              <rect width="64" height="64" rx="32" fill="currentColor" opacity="0.15"/>
                              <circle cx="32" cy="26" r="11" fill="currentColor" opacity="0.4"/>
                              <ellipse cx="32" cy="54" rx="18" ry="12" fill="currentColor" opacity="0.3"/>
                            </svg>
                            <span class="testimonial-avatar-initial">{t.initial}</span>
                          </>
                        )}
                      </div>
                      <div class="text-left">
                        <p class="text-sm font-semibold text-foreground">{t.name}</p>
                        <p class="text-xs text-foreground-muted">{t.role}</p>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Dots -->
            <div class="testimonial-dots" aria-hidden="true">
              {testimonials.map((t, i) => (
                <button class={`testimonial-dot${i === 0 ? ' active' : ''}`} data-slide={i} aria-label={`Go to testimonial ${i + 1}`}></button>
              ))}
            </div>
          </div>
        );
      })()}
    </div>
  </section>

  <!-- Tool Marquee -->
  <ToolMarquee
    badge="My Toolstack"
    title="Tools I work with"
    background="primary"
  />

  <!-- About Teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center" data-reveal="right">
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start">About Shrishti</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Marketing, Systems<br />
              <span class="text-brand-500">and Psychology.</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            8 years of marketing experience has taught me one thing — people don't remember you or your product but they do remember how you made them feel. And it's that feeling that I deliver to audiences. I'm an empath, a feeler, blessed with a logical mind — and that's a dangerous combination for reverse engineering and delivering what people want.
          </p>
          <Button variant="outline" href={url("/about")} class="self-start">
            More about me
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1">
          <p class="text-sm text-foreground mb-5 text-center">A few things about me.</p>
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="history" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">8 Years Experience</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="briefcase" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">100+ Projects</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="globe" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Working worldwide</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="map-pin" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Based in India</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start">From the newsletter</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Latest reads
          </h2>
        </div>
        <a href={url("/blog")} class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.title}
            description={post.description}
            href={post.href}
            publishedAt={post.publishedAt}
            tags={post.tags}
            author={post.author}
            imageUrl={post.imageUrl}
          />
        ))}
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href={url("/blog")}>
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Have a project in mind?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Let's talk. Book a direct call with me or connect via other channels.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="cta-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={url("/contact")}>
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Have a project in mind?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Let's talk. Book a direct call with me or connect via other channels.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://calendly.com/shrishtisnagar/1-1-clarity-call-with-shrishti" target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
          Book a call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href={url("/contact")}>
          Contact
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>

<style>
  .hero-photo-wrap {
    position: relative;
    width: 16rem;
    height: 16rem;
  }

  @media (min-width: 768px) {
    .hero-photo-wrap {
      width: 20rem;
      height: 20rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-photo-wrap {
      width: 24rem;
      height: 24rem;
    }
  }

  .hero-photo {
    position: relative;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 1rem;
    -webkit-mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
    mask-image: radial-gradient(ellipse 85% 85% at 50% 45%, black 40%, transparent 100%);
  }

  /* ---- Brand logo marquee ---- */
  .brand-marquee-track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .brand-marquee-inner {
    display: flex;
    align-items: center;
    gap: 0;
    width: max-content;
    animation: brand-scroll 30s linear infinite;
  }

  .brand-marquee-track:hover .brand-marquee-inner {
    animation-play-state: paused;
  }

  @keyframes brand-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .brand-logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 11rem;
    flex-shrink: 0;
    opacity: 0.55;
    transition: opacity 0.25s ease;
  }

  .brand-logo-item:hover {
    opacity: 1;
  }

  .brand-logo-item img {
    width: 7rem;
    height: 3.5rem;
    object-fit: contain;
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-marquee-inner { animation: none; }
  }

  /* ---- Project thumbnail ---- */
  .project-thumb {
    position: relative;
    height: 9rem;
    background: linear-gradient(
      135deg,
      oklch(18% 0.04 344) 0%,
      oklch(14% 0.03 344) 100%
    );
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-thumb::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 70% 70% at 30% 40%,
      oklch(40% 0.08 344 / 0.35) 0%,
      transparent 70%
    );
  }

  .project-thumb-icon {
    position: relative;
    z-index: 1;
    color: oklch(81% 0.09 344 / 0.5);
  }

  /* ---- Testimonial carousel ---- */
  .testimonial-carousel {
    position: relative;
    max-width: 42rem;
    margin: 0 auto;
  }

  .testimonial-slides {
    position: relative;
    min-height: 280px;
  }

  .testimonial-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
  }

  .testimonial-slide.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .testimonial-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .testimonial-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-brand-500, #f7b5dd) 30%, transparent);
    border: none;
    cursor: pointer;
    transition: background 0.3s, width 0.3s;
    padding: 0;
  }

  .testimonial-dot.active {
    width: 1.5rem;
    background: var(--color-brand-500, #f7b5dd);
  }

  .testimonial-avatar {
    position: relative;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    color: var(--color-brand-500, #f7b5dd);
  }

  .testimonial-avatar svg {
    width: 100%;
    height: 100%;
  }

  .testimonial-avatar-initial {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-brand-500, #f7b5dd);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonial-slide { transition: none; }
  }
</style>

<script>
  function initTestimonialCarousel() {
    const carousel = document.querySelector('.testimonial-carousel');
    if (!carousel) return;

    const slides = carousel.querySelectorAll<HTMLElement>('.testimonial-slide');
    const dots = carousel.querySelectorAll<HTMLElement>('.testimonial-dot');
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('active');

      current = (index + slides.length) % slides.length;

      slides[current].classList.add('active');
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current].classList.add('active');
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goTo(i);
        startAuto();
      });
    });

    startAuto();
  }

  initTestimonialCarousel();

  function initCountup() {
    const counters = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-countup-init])');
    if (counters.length === 0) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countup ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((el) => {
      el.dataset.countupInit = 'true';
      observer.observe(el);
    });
  }

  initCountup();
</script>

</LandingLayout>
